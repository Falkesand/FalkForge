<UserControl x:Class="MAS.Views.InstallationTypeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F0F0">
    <Grid Margin="16,12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Standard installation -->
        <StackPanel Grid.Column="0">
            <RadioButton Content="{Binding StandardRadio}"
                         IsChecked="{Binding IsStandard}"
                         FontWeight="Bold" FontSize="13" Margin="0,0,0,4" />
            <TextBlock Text="{Binding StandardDescription}"
                       TextWrapping="Wrap" Margin="20,0,0,8" FontSize="12"
                       Foreground="#333333" />
            <Border BorderBrush="#AAAAAA" BorderThickness="1"
                    Background="White" Padding="10" Margin="4,4,4,0">
                <TextBlock TextWrapping="Wrap" FontSize="12">
                    <Run FontWeight="Bold"
                         Text="{Binding DataContext.StandardDetailsHeader, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    <LineBreak />
                    <Run
                        Text="{Binding DataContext.StandardDetail1, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    <LineBreak />
                    <Run
                        Text="{Binding DataContext.StandardDetail1a, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    <LineBreak />
                    <Run
                        Text="{Binding DataContext.StandardDetail1b, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    <LineBreak />
                    <Run
                        Text="{Binding DataContext.StandardDetail1c, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    <LineBreak />
                    <Run
                        Text="{Binding DataContext.StandardDetail1d, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    <LineBreak />
                    <Run
                        Text="{Binding DataContext.StandardDetail2, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    <LineBreak />
                    <Run
                        Text="{Binding DataContext.StandardDetail2a, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    <LineBreak />
                    <Run
                        Text="{Binding DataContext.StandardDetail3, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    <LineBreak />
                    <Run
                        Text="{Binding DataContext.StandardDetail4, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                </TextBlock>
            </Border>
        </StackPanel>

        <!-- Advanced installation -->
        <StackPanel Grid.Column="2">
            <RadioButton Content="{Binding AdvancedRadio}"
                         IsChecked="{Binding IsAdvanced}"
                         FontWeight="Bold" FontSize="13" Margin="0,0,0,4" />
            <TextBlock Text="{Binding AdvancedDescription}"
                       TextWrapping="Wrap" Margin="20,0,0,8" FontSize="12"
                       Foreground="#333333" />
            <Border BorderBrush="#AAAAAA" BorderThickness="1"
                    Background="White" Padding="10" Margin="4,4,4,0">
                <TextBlock TextWrapping="Wrap" FontSize="12">
                    <Run
                        Text="{Binding DataContext.AdvancedDetail1, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    <LineBreak />
                    <Run
                        Text="{Binding DataContext.AdvancedDetail2, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    <LineBreak />
                    <Run
                        Text="{Binding DataContext.AdvancedDetail3, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    <LineBreak />
                    <Run
                        Text="{Binding DataContext.AdvancedDetail4, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    <LineBreak />
                    <Run
                        Text="{Binding DataContext.AdvancedDetail4a, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    <LineBreak />
                    <Run
                        Text="{Binding DataContext.AdvancedDetail5, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    <LineBreak />
                    <Run
                        Text="{Binding DataContext.AdvancedDetail6, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    <LineBreak />
                    <Run
                        Text="{Binding DataContext.AdvancedDetail6a, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                </TextBlock>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>