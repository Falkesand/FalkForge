<UserControl x:Class="MAS.Views.DatabaseServerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shell="clr-namespace:MAS.Shell"
             Background="#F0F0F0">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <shell:InverseBooleanConverter x:Key="InverseBool" />
    </UserControl.Resources>
    <Grid Margin="16,12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left panel: database mode selection and info -->
        <StackPanel Grid.Column="0">
            <RadioButton Content="{Binding UseExistingRadioText}"
                         IsChecked="{Binding UseExisting}"
                         FontWeight="SemiBold" FontSize="12"
                         Margin="0,0,0,4" />
            <RadioButton Content="{Binding CreateEmptyRadioText}"
                         IsChecked="{Binding CreateEmpty}"
                         FontWeight="SemiBold" FontSize="12"
                         Margin="0,0,0,12" />
            <Border BorderBrush="#AAAAAA" BorderThickness="1"
                    Background="White" Padding="10" Margin="4,4,4,0">
                <TextBlock TextWrapping="Wrap" FontSize="12"
                           Text="{Binding InfoText}" />
            </Border>
        </StackPanel>

        <!-- Right panel: server search and database name -->
        <StackPanel Grid.Column="2">
            <TextBlock Text="{Binding ServerLabel}" FontWeight="SemiBold"
                       FontSize="12" Margin="0,0,0,4" />
            <Border BorderBrush="#AAAAAA" BorderThickness="1"
                    Background="White" Padding="8" Margin="0,0,0,4">
                <StackPanel>
                    <Grid Margin="0,4,0,4">
                        <Button x:Name="SearchButton" HorizontalAlignment="Stretch"
                                Padding="8,6" Height="32"
                                Click="SearchServer_Click"
                                IsEnabled="{Binding IsSearching, Converter={StaticResource InverseBool}}">
                            <TextBlock Text="{Binding SearchButtonContent}"
                                       HorizontalAlignment="Center" FontSize="12" />
                        </Button>
                        <!-- Blue bounce bar overlaid at the bottom of the button -->
                        <Canvas Height="3" VerticalAlignment="Bottom" Margin="1,0,1,1"
                                ClipToBounds="True"
                                Visibility="{Binding IsSearching, Converter={StaticResource BoolToVis}}">
                            <Rectangle x:Name="BounceBar" Canvas.Left="0" Canvas.Top="0"
                                       Width="60" Height="3" Fill="#2196F3" RadiusX="1.5" RadiusY="1.5" />
                        </Canvas>
                    </Grid>
                    <ComboBox x:Name="ServerCombo" IsEditable="True"
                              Text="{Binding DatabaseServer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              ItemsSource="{Binding AvailableServers}"
                              FontSize="12"
                              BorderBrush="#AAAAAA" />
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding DatabaseNameLabel}" FontWeight="SemiBold"
                       FontSize="12" Margin="0,16,0,4" />
            <ComboBox Text="{Binding DatabaseName, UpdateSourceTrigger=PropertyChanged}"
                      ItemsSource="{Binding AvailableDatabases}"
                      IsEditable="True" FontSize="12"
                      BorderBrush="#AAAAAA"
                      DropDownOpened="DatabaseCombo_DropDownOpened" />
        </StackPanel>
    </Grid>
</UserControl>