<UserControl x:Class="MAS.Views.InstallProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F0F0">
    <Grid Margin="40,60,40,20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="{Binding StatusText, Mode=OneWay}" FontSize="14"
                       HorizontalAlignment="Center" Margin="0,0,0,16" />
            <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}" Minimum="0" Maximum="100"
                         Height="24" Margin="0,0,0,8" />
            <TextBlock Text="{Binding ProgressDetail, Mode=OneWay}" FontSize="11"
                       Foreground="#666666" HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>
