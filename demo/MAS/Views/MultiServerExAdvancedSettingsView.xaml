<UserControl x:Class="MAS.Views.MultiServerExAdvancedSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:FalkForge.Ui;assembly=FalkForge.Ui"
             xmlns:shell="clr-namespace:MAS.Shell"
             Background="#F0F0F0">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <shell:InverseBooleanConverter x:Key="InverseBool" />
    </UserControl.Resources>
    <StackPanel Margin="20,8,20,8">
        <!-- ODBC DSN configuration -->
        <GroupBox Header="{Binding OdbcGroupHeader}" FontSize="12" Padding="12,8" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="{Binding DsnNameLabel}" FontWeight="Bold" FontSize="12" Margin="0,0,0,4" />
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding DsnName, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="12" Padding="4,4" BorderBrush="#AAAAAA" />
                    <Button Grid.Column="1" Margin="8,0,0,0" Padding="8,4"
                            Click="CheckDsn_Click"
                            IsEnabled="{Binding IsChecking, Converter={StaticResource InverseBool}}">
                        <StackPanel>
                            <TextBlock Text="{Binding CheckButtonContent}"
                                       HorizontalAlignment="Center" FontSize="11" />
                            <ProgressBar IsIndeterminate="True" Height="3" Margin="0,3,0,0"
                                         Visibility="{Binding IsChecking, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </Button>
                </Grid>
                <TextBlock Text="{Binding DsnWarning}" FontSize="11"
                           Foreground="#CC0000" TextWrapping="Wrap"
                           Margin="0,2,0,0" />
                <Button Content="{Binding OdbcAdminButtonText}"
                        HorizontalAlignment="Center" Padding="12,4"
                        FontSize="12" Margin="0,8,0,0"
                        Click="OdbcAdmin_Click" />
            </StackPanel>
        </GroupBox>

        <!-- Windows service configuration -->
        <GroupBox Header="{Binding ServiceGroupHeader}" FontSize="12" Padding="12,8">
            <StackPanel>
                <TextBlock Text="{Binding ServiceNameLabel}" FontSize="12" Margin="0,0,0,2" />
                <TextBlock Text="{Binding ServiceName}" FontWeight="Bold"
                           FontSize="12" Margin="0,0,0,8" />

                <TextBlock Text="{Binding ServiceAccountLabel}" FontSize="12" Margin="0,0,0,4" />
                <TextBox Text="{Binding ServiceAccount, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="12" Padding="4,4" BorderBrush="#AAAAAA"
                         Margin="0,0,0,2" />

                <Border Background="#FFFF00" Padding="4,2" Margin="0,0,0,4">
                    <TextBlock Text="{Binding ServiceWarning}" FontSize="11"
                               TextWrapping="Wrap" />
                </Border>

                <TextBlock Text="{Binding IntegratedSecurityNote}" FontSize="11"
                           TextWrapping="Wrap" Foreground="#555555"
                           Margin="0,0,0,8" />

                <TextBlock Text="{Binding PasswordLabel}" FontSize="12" Margin="0,0,0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <PasswordBox Grid.Column="0" FontSize="12" Padding="4,4"
                                 BorderBrush="#AAAAAA"
                                 ui:PasswordBridge.Key="MultiServerExServicePassword" />
                    <Button Grid.Column="1" Content="{Binding DataContext.ShowButtonText, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=Show}"
                            Width="40" Margin="4,0,0,0"
                            ToolTip="{Binding DataContext.ShowPasswordTooltip, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue='Show password'}" />
                </Grid>
            </StackPanel>
        </GroupBox>
    </StackPanel>
</UserControl>