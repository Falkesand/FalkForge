<UserControl x:Class="CustomUiVsStyle.Views.WorkloadsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">
    <UserControl.Resources>
        <ResourceDictionary Source="/Themes/DarkTheme.xaml" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="400" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>

        <!-- Left: Workload list -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="24,16">
            <StackPanel>
                <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold"
                           Foreground="#CCCCCC" Margin="0,0,0,16" />

                <ItemsControl ItemsSource="{Binding Workloads}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#252526" CornerRadius="4"
                                    Padding="16,12" Margin="0,0,0,8"
                                    BorderBrush="#3E3E42" BorderThickness="1"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="Workload_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                              VerticalAlignment="Top" Margin="0,2,12,0" />

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" FontSize="14"
                                                   FontWeight="SemiBold" Foreground="#CCCCCC" />
                                        <TextBlock Text="{Binding Description}" FontSize="12"
                                                   Foreground="#969696" TextWrapping="Wrap"
                                                   Margin="0,4,0,0" LineHeight="18" />
                                    </StackPanel>

                                    <TextBlock Grid.Column="2" Text="{Binding Size}"
                                               FontSize="12" Foreground="#969696"
                                               VerticalAlignment="Top" Margin="12,2,0,0" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Total size footer -->
                <Border Background="#252526" CornerRadius="4" Padding="16,10" Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding TotalSelectedLabel}" FontSize="13" Foreground="#969696"
                                   Margin="0,0,4,0" />
                        <TextBlock Text="{Binding TotalSelectedSize}" FontSize="13"
                                   FontWeight="SemiBold" Foreground="#CCCCCC" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Divider -->
        <Rectangle Grid.Column="1" Fill="#3E3E42" />

        <!-- Right: Component details -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel>
                <TextBlock Text="{Binding ComponentsLabel}" FontSize="14" FontWeight="SemiBold"
                           Foreground="#CCCCCC" Margin="0,0,0,12" />

                <ItemsControl ItemsSource="{Binding SelectedWorkload.Components}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontSize="12" Foreground="#CCCCCC" Margin="0,0,4,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="&#x25CB;" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRequired}" Value="True">
                                                        <Setter Property="Text" Value="&#x25CF;" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Name}" FontSize="12" Foreground="#CCCCCC" />
                                </StackPanel>
                                <TextBlock FontSize="11" Foreground="#696969" Margin="16,2,0,0">
                                    <Run Text="{Binding Size, Mode=OneWay}" />
                                    <Run>
                                        <Run.Style>
                                            <Style TargetType="Run">
                                                <Setter Property="Text" Value="" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRequired}" Value="True">
                                                        <Setter Property="Text"
                                                                Value="{Binding DataContext.RequiredLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Run.Style>
                                    </Run>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="{Binding SelectPrompt}"
                           FontSize="12" Foreground="#696969" FontStyle="Italic"
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedWorkload}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>