<UserControl x:Class="CustomUiVsStyle.Views.ProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">
    <UserControl.Resources>
        <ResourceDictionary Source="/Themes/DarkTheme.xaml"/>
    </UserControl.Resources>

    <Grid Margin="40,32">
        <StackPanel VerticalAlignment="Top" MaxWidth="700" HorizontalAlignment="Left">
            <TextBlock Text="Installing FalkForge DevTools Suite" FontSize="20"
                       FontWeight="SemiBold" Foreground="#CCCCCC" Margin="0,0,0,8"/>
            <TextBlock Text="{Binding CurrentOperation}" FontSize="13"
                       Foreground="#969696" Margin="0,0,0,24"/>

            <!-- Overall progress -->
            <TextBlock Text="Overall progress" FontSize="12" Foreground="#969696" Margin="0,0,0,6"/>
            <ProgressBar Value="{Binding OverallProgress}" Maximum="100" Height="6"
                         Background="#252526" Foreground="#7B68EE" BorderThickness="0"
                         Margin="0,0,0,32"/>

            <!-- Per-workload progress -->
            <ItemsControl ItemsSource="{Binding InstallingWorkloads}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,16">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Name}"
                                           FontSize="13" Foreground="#CCCCCC"/>
                                <TextBlock Grid.Column="1" FontSize="12" Foreground="#969696">
                                    <Run Text="{Binding Progress, StringFormat={}{0:F0}%, Mode=OneWay}"/>
                                </TextBlock>
                            </Grid>
                            <ProgressBar Value="{Binding Progress}" Maximum="100" Height="4"
                                         Background="#252526" Foreground="#4EC9B0" BorderThickness="0"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</UserControl>
