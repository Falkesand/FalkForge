# EditorConfig — FalkForge
# https://editorconfig.org

root = true

[*]
indent_style = space
indent_size = 4
end_of_line = crlf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{csproj,props,targets,slnx}]
indent_size = 2

[*.{json,yaml,yml}]
indent_size = 2

[*.cs]

# ─────────────────────────────────────────────────────────────
# Dead-code detection — promoted to warning (build errors via
# TreatWarningsAsErrors). Requires EnforceCodeStyleInBuild for
# the IDE-prefixed rules to fire during build.
# ─────────────────────────────────────────────────────────────
dotnet_diagnostic.CA1812.severity = warning      # Avoid uninstantiated internal classes
dotnet_diagnostic.IDE0051.severity = warning     # Remove unused private member
dotnet_diagnostic.IDE0052.severity = warning     # Remove unread private member

# ─────────────────────────────────────────────────────────────
# AnalysisLevel latest-all (C10) — curated severity tiering.
# `latest-all` turns on the full .NET CA rule set (not just the
# "recommended" default subset). The rules below fired in bulk
# across src on first enable; each is demoted with a rationale
# rather than suppressed wholesale. Rules explicitly flagged by
# the C10 plan item as worth independently mining for real bugs
# later (CA1307, CA2007, CA1062, CA1031, CA1305) are tiered to
# `suggestion` so the signal stays visible without failing the
# build. Structural/API-shape rules whose "fix" would be a public
# API break or a deliberate design choice are tiered the same way
# so they remain visible without blocking. Test-naming (CA1707) is
# handled separately in tests/.editorconfig.
# ─────────────────────────────────────────────────────────────
dotnet_diagnostic.CA1707.severity = none         # Rule-ID naming convention (Pkg001_NameRequired, Fea001_IdRequired, ...) is intentional — documented in CLAUDE.md's Validation rule-ID scheme, not renameable
dotnet_diagnostic.CA1062.severity = suggestion   # Null-check public params — C10 plan: mine independently (326 occurrences), too broad to fix in a config PR
dotnet_diagnostic.CA1305.severity = suggestion   # IFormatProvider on locale-sensitive calls — C10 plan: mine independently (163 occurrences)
dotnet_diagnostic.CA1307.severity = suggestion   # StringComparison overloads — C10 plan: mine independently
dotnet_diagnostic.CA1031.severity = suggestion   # Catch specific exception types — C10 plan: mine independently (98 occurrences)
dotnet_diagnostic.CA2007.severity = suggestion   # ConfigureAwait(false) — C10 plan: mine independently
dotnet_diagnostic.CA1056.severity = suggestion   # string -> Uri property type — would break public builder API (e.g. SigningOptionsBuilder.TimestampUrl)
dotnet_diagnostic.CA1054.severity = suggestion   # string -> Uri parameter type — same public API concern as CA1056
dotnet_diagnostic.CA2225.severity = suggestion   # Friendly alternate method names for operators — deliberate operator-based fluent DSL (Condition, MsiProperty, InstallPath, KnownFolder)
dotnet_diagnostic.CA1720.severity = suggestion   # Identifier contains type name — enum members (RegistryValueType.String, CustomTableColumnType.Int32, ...) intentionally match the primitive/registry type they represent
dotnet_diagnostic.CA1034.severity = suggestion   # Nested public type — deliberate scoped pattern (e.g. SensitiveBytes.RevealScope)
dotnet_diagnostic.CA1815.severity = suggestion   # Struct should override Equals/== — SensitiveBytes/RevealScope wrap secret data; naive byte equality risks a timing side-channel, needs a dedicated security-reviewed design, not a config-PR fix
dotnet_diagnostic.CA1308.severity = suggestion   # Prefer ToUpperInvariant — lowercase output is required by external format conventions (file-association verbs, WinGet YAML keys); switching case would change behavior
dotnet_diagnostic.CA1000.severity = suggestion   # Static members on generic types — Result<T>.Success/Failure is the documented canonical factory pattern (CLAUDE.md)
dotnet_diagnostic.CA1819.severity = suggestion   # Properties should not return arrays — would change public model property types (WinGetConfig), breaking API
dotnet_diagnostic.CA1716.severity = suggestion   # Reserved keyword identifier — Core.Error is the documented canonical type name used throughout the codebase; renaming is a sweeping breaking change
dotnet_diagnostic.CA1810.severity = suggestion   # Prefer inline static field init over static ctor — MiscRules' static ctor is required for cross-partial init ordering (see adjacent S3963 suppression)
dotnet_diagnostic.CA1028.severity = suggestion   # Enum underlying type should be Int32 — cosmetic; PathSegment.Kind is an internal formatting detail, not on a wire format
dotnet_diagnostic.CA1002.severity = suggestion   # List<T> in public API — would change ServiceBuilder.Dependencies' public type, breaking API
dotnet_diagnostic.CA1032.severity = suggestion   # Standard exception constructors — FieldMismatchException is always thrown with a diagnostic message by design; adding a message-less ctor would invite misuse
dotnet_diagnostic.CA1822.severity = suggestion   # Member could be static — MsixBundleCompiler/MsixCompiler.Compile are public instance API; making them static breaks existing `instance.Compile(...)` call sites
dotnet_diagnostic.CA1051.severity = suggestion   # Visible instance fields — PipeTransportBase's protected fields are used directly by PipeServer/PipeClient; converting to properties is a wider refactor, out of scope for C10
dotnet_diagnostic.CA1003.severity = suggestion   # Action event vs EventHandler<T> — PipeTransportBase.PipeClosed's signature change would break existing subscribers, out of scope for C10
dotnet_diagnostic.CA1711.severity = suggestion   # Reserved type-name suffix — DriverInstallFlags/FileSharePermission are established public enum names; renaming is a breaking API change
dotnet_diagnostic.CA1030.severity = suggestion   # "Should be an event" false positive — UserBuilder.RemoveOnUninstall() is a fluent-builder configuration method, matching the rest of that DSL
dotnet_diagnostic.CA1515.severity = suggestion   # "Type could be internal" — fires broadly on FalkForge.Ui's intentionally-public extension surface (InstallerPage, InstallerApp, ViewModels, ...) consumed by demos/downstream custom-UI projects, plus Engine.Elevation's command types; too broad and API-risky to blanket-fix in a config PR
dotnet_diagnostic.CA1069.severity = suggestion   # Duplicate enum value — MsiControlAttributes intentionally reuses bit positions across MSI control types per the Win32 Control table spec (see file header remarks)
dotnet_diagnostic.CA2000.severity = suggestion   # Dispose before scope exit — mixed verdict: CabinetExtractor's FdiHandle is created here but disposed by RunFdiCopy after ownership transfer (cross-method dataflow the analyzer can't see; already correct, see inline comment on the GC.KeepAlive ordering); DefaultShellViewModel's page ViewModels are a genuine gap (InstallerShellViewModel never disposes registered pages) flagged here for a dedicated follow-up, not a config-PR fix
dotnet_diagnostic.CA2025.severity = suggestion   # Task using IDisposable before dispose — InstallerApp's fire-and-forget DeliverSecretAsync owns and disposes its NamedPipeServerStream itself in its own finally block; cross-method dataflow false positive
dotnet_diagnostic.CA1859.severity = suggestion   # Concrete-type perf suggestion — most straightforward occurrences already narrowed in code (SqlServerDiscovery, VfsMapper, DeltaBundleCompiler); remaining ones are false positives: CabinetExtractor._chainResolver is deliberately an interface for test injection (see inline comment), and InstallerApp.ResolveEngine's return type participates in `?? new NullInstallerEngine()`, which would stop compiling if narrowed
dotnet_diagnostic.CA1806.severity = suggestion   # Unchecked TryParse result — the decompiler intentionally relies on TryParse's documented "out param = default on failure" contract as its fallback (Version.TryParse -> DefaultVersion via ??=, Guid.TryParse -> Guid.Empty); an explicit if-check would add no value
dotnet_diagnostic.CA1862.severity = suggestion   # Prefer case-insensitive string.Equals — MsiPackageReconstructor's `p.Property == p.Property.ToUpperInvariant()` tests whether a string IS already all-uppercase (MSI secure-property convention); it is not an equality comparison, and a case-insensitive Equals here would always return true, which is a real behavior change, not a fix
dotnet_diagnostic.CA1068.severity = suggestion   # CancellationToken should be last parameter — IElevationClient.SendCommandAsync's (token, progress) order is an established public interface implemented/called across 5+ files; reordering is a breaking ripple, out of scope for C10
dotnet_diagnostic.CA2227.severity = suggestion   # Read-only collection property — fires broadly on System.Text.Json [JsonPropertyName] DTOs (Cli/Models/*Config.cs, Studio/Project/*.cs); those setters are required for JSON deserialization, removing them would break config/project loading
dotnet_diagnostic.CA1724.severity = suggestion   # Type/namespace name collision — Studio.Graph.DependencyGraph vs. the Studio.Editors.DependencyGraph namespace; renaming ripples across 5+ files including XAML bindings, out of scope for C10
dotnet_diagnostic.CA1303.severity = suggestion   # Literal string passed to a localizable-string parameter — only observed in demo/ Console.WriteLine sample output; FalkForge's actual UI text goes through the dedicated Localization/UiStringResolver system (see CLAUDE.md), not per-string resource tables for CLI/demo messaging; InvariantGlobalization=true on the shipping exes (Engine, Elevation) already signals globalization is intentionally out of scope there

# ─────────────────────────────────────────────────────────────
# Meziantou.Analyzer — code quality, fix incrementally
# ─────────────────────────────────────────────────────────────
dotnet_diagnostic.MA0002.severity = suggestion   # IEqualityComparer/IComparer parameter
dotnet_diagnostic.MA0004.severity = suggestion   # Use ConfigureAwait
dotnet_diagnostic.MA0006.severity = suggestion   # Use string.Equals instead of == operator
dotnet_diagnostic.MA0009.severity = suggestion   # Regex DoS — internal validation on trusted builder input
dotnet_diagnostic.MA0015.severity = suggestion   # ArgumentException with parameter name
dotnet_diagnostic.MA0021.severity = suggestion   # Explicit StringComparer for hash codes
dotnet_diagnostic.MA0011.severity = suggestion   # IFormatProvider parameter
dotnet_diagnostic.MA0016.severity = suggestion   # Prefer collection abstraction
dotnet_diagnostic.MA0023.severity = suggestion   # RegexOptions.ExplicitCapture
dotnet_diagnostic.MA0048.severity = none         # File name must match type name — conflicts with project conventions
dotnet_diagnostic.MA0051.severity = suggestion   # Method is too long
dotnet_diagnostic.MA0074.severity = none         # Avoid implicit culture-sensitive ToString — false positives on test params
dotnet_diagnostic.MA0076.severity = suggestion   # Do not use implicit culture-sensitive ToString in interpolated strings
dotnet_diagnostic.MA0017.severity = suggestion   # Abstract types should not have public constructors
dotnet_diagnostic.MA0046.severity = suggestion   # Use EventHandler<T> to declare events
dotnet_diagnostic.MA0055.severity = suggestion   # Do not use finalizer
dotnet_diagnostic.MA0134.severity = suggestion   # Observe result of async calls
dotnet_diagnostic.MA0158.severity = suggestion   # Use System.Threading.Lock

# ─────────────────────────────────────────────────────────────
# SonarAnalyzer — code smells, fix incrementally
# ─────────────────────────────────────────────────────────────
dotnet_diagnostic.S101.severity = suggestion     # Type naming convention
dotnet_diagnostic.S1075.severity = suggestion    # URIs should not be hardcoded
dotnet_diagnostic.S1144.severity = suggestion    # Unused private members
dotnet_diagnostic.S1121.severity = suggestion    # Extract assignment from expression
dotnet_diagnostic.S1125.severity = suggestion    # Unnecessary boolean literal
dotnet_diagnostic.S1172.severity = suggestion    # Unused method parameter
dotnet_diagnostic.S1199.severity = suggestion    # Nested code blocks
dotnet_diagnostic.S2094.severity = suggestion    # Remove empty class
dotnet_diagnostic.S2325.severity = suggestion    # Make member static
dotnet_diagnostic.S2344.severity = suggestion    # Enum name should not match member
dotnet_diagnostic.S3011.severity = suggestion    # Reflection accessibility bypass
dotnet_diagnostic.S3241.severity = suggestion    # Method return type more derived
dotnet_diagnostic.S3267.severity = suggestion    # Loop simplified with LINQ Where
dotnet_diagnostic.S3358.severity = suggestion    # Ternary complexity
dotnet_diagnostic.S3869.severity = suggestion    # Parameter names should match base
dotnet_diagnostic.S3878.severity = none          # Remove unused parameter — false positive on xUnit v3 test data
dotnet_diagnostic.S3923.severity = suggestion    # Identical branches
dotnet_diagnostic.S3973.severity = suggestion    # Use curly braces for conditionally executed code
dotnet_diagnostic.S4050.severity = suggestion    # Provide operator== and operator!=
dotnet_diagnostic.S4136.severity = suggestion    # Equals overloads should be adjacent
dotnet_diagnostic.S4144.severity = suggestion    # Methods returning identical values
dotnet_diagnostic.S4220.severity = suggestion    # Events should use EventHandler<T>
dotnet_diagnostic.S5445.severity = suggestion    # Insecure temporary file creation
dotnet_diagnostic.S6588.severity = suggestion    # Use span-based string.Split overload
dotnet_diagnostic.S2930.severity = suggestion    # Dispose IDisposable fields
dotnet_diagnostic.S6561.severity = suggestion    # Avoid DateTime.Now for benchmarking
dotnet_diagnostic.S6608.severity = suggestion    # Prefer indexing from end
dotnet_diagnostic.S6966.severity = suggestion    # Await CancelAsync instead
dotnet_diagnostic.S3427.severity = suggestion    # Method overloads with default parameter
dotnet_diagnostic.S108.severity = suggestion     # Nested block should not be empty
dotnet_diagnostic.S125.severity = suggestion     # Commented-out code
dotnet_diagnostic.S127.severity = suggestion     # Do not update loop counter in body
dotnet_diagnostic.S1066.severity = suggestion    # Collapsible if statements
dotnet_diagnostic.S1481.severity = suggestion    # Unused local variables
dotnet_diagnostic.S1643.severity = suggestion    # Use StringBuilder instead
dotnet_diagnostic.S1854.severity = suggestion    # Unused assignments
dotnet_diagnostic.S1871.severity = suggestion    # Branches with identical implementation
dotnet_diagnostic.S2486.severity = suggestion    # Generic exceptions should not be silenced
dotnet_diagnostic.S3442.severity = suggestion    # Abstract class constructor visibility
dotnet_diagnostic.S3604.severity = suggestion    # Member initializer duplicates constructor
dotnet_diagnostic.S6562.severity = suggestion    # Always set a timeout for HttpClient
dotnet_diagnostic.S927.severity = suggestion     # Parameter name mismatch

# ─────────────────────────────────────────────────────────────
# IDisposableAnalyzers — track as suggestions, fix incrementally
# Promoted to warning once existing violations are cleaned up
# ─────────────────────────────────────────────────────────────
dotnet_diagnostic.IDISP001.severity = suggestion # Dispose created
dotnet_diagnostic.IDISP003.severity = suggestion # Dispose previous before re-assigning
dotnet_diagnostic.IDISP004.severity = suggestion # Don't ignore created IDisposable
dotnet_diagnostic.IDISP005.severity = suggestion # Return type should indicate IDisposable
dotnet_diagnostic.IDISP006.severity = suggestion # Implement IDisposable
dotnet_diagnostic.IDISP007.severity = suggestion # Don't dispose injected
dotnet_diagnostic.IDISP008.severity = suggestion # Don't mix injected and created
dotnet_diagnostic.IDISP016.severity = suggestion # Don't use disposed instance
dotnet_diagnostic.IDISP017.severity = suggestion # Prefer using
dotnet_diagnostic.IDISP002.severity = suggestion # Dispose member
dotnet_diagnostic.IDISP023.severity = suggestion # Don't use reference types in finalizer
dotnet_diagnostic.IDISP026.severity = suggestion # Sealed disposable should suppress finalizer

# ─────────────────────────────────────────────────────────────
# Threading Analyzers — keep most as warnings (real bugs)
# ─────────────────────────────────────────────────────────────
dotnet_diagnostic.VSTHRD002.severity = suggestion # Avoid problematic synchronous waits
dotnet_diagnostic.VSTHRD001.severity = suggestion # Avoid awaiting non-joinable tasks
dotnet_diagnostic.VSTHRD003.severity = suggestion # Avoid awaiting foreign tasks
dotnet_diagnostic.VSTHRD100.severity = suggestion # Avoid async void methods
dotnet_diagnostic.VSTHRD101.severity = suggestion # Avoid unsupported async delegates
dotnet_diagnostic.VSTHRD103.severity = suggestion # Call async methods when in async method
dotnet_diagnostic.VSTHRD110.severity = suggestion # Observe result of async calls
dotnet_diagnostic.VSTHRD200.severity = suggestion # Use Async suffix for async methods

# ─────────────────────────────────────────────────────────────
# WpfAnalyzers
# ─────────────────────────────────────────────────────────────
# ───────────────────────────────���─────────────────────────────
# SecurityCodeScan — security, review individually
# ─────────────────────────────────────────���───────────────────
dotnet_diagnostic.SCS0005.severity = suggestion  # Weak random — many are in test code, not security-critical

