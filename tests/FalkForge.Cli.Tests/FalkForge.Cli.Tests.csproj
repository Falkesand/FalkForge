<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <!-- Deliberate opt-in to the .NET 10 ML-DSA (FIPS 204) API for PQ-hybrid manifest signing —
         see the rationale comment in src/FalkForge.Core/FalkForge.Core.csproj. -->
    <NoWarn>$(NoWarn);SYSLIB5006</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="xunit.v3" />
    <ProjectReference Include="..\..\src\FalkForge.Cli\FalkForge.Cli.csproj" />
    <ProjectReference Include="..\..\src\FalkForge.Compiler.Bundle\FalkForge.Compiler.Bundle.csproj" />
    <ProjectReference Include="..\..\src\FalkForge.Testing\FalkForge.Testing.csproj" />
  </ItemGroup>
</Project>
