<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="xunit.v3" />
  </ItemGroup>
  <ItemGroup>
    <!-- Build-order dependency only, never referenced from C#; see FakeSigil's own csproj
         comment. ReferenceOutputAssembly=false deliberately means "build it, but do not copy its
         output here or add an assembly reference": Windows searches a launching process's OWN
         directory before PATH, so copying sigil.exe next to this test host would make it always
         "on PATH" even with PATH cleared, breaking Compile_WithIntegrity_SignsWithEcdsa_...'s
         "sigil unreachable" invariant. MsiIntegritySigningTests instead resolves FakeSigil's own
         build output directory at run time and prepends THAT to PATH only where it deliberately
         wants sigil reachable. -->
    <ProjectReference Include="..\FalkForge.Compiler.Msi.Tests.FakeSigil\FalkForge.Compiler.Msi.Tests.FakeSigil.csproj"
                       ReferenceOutputAssembly="false" Private="false" />
    <ProjectReference Include="..\..\src\FalkForge.Compiler.Msi\FalkForge.Compiler.Msi.csproj" />
    <ProjectReference Include="..\..\src\FalkForge.Extensibility\FalkForge.Extensibility.csproj" />
    <ProjectReference Include="..\..\src\FalkForge.Extensions.Dependency\FalkForge.Extensions.Dependency.csproj" />
    <ProjectReference Include="..\..\src\FalkForge.Extensions.Driver\FalkForge.Extensions.Driver.csproj" />
    <ProjectReference Include="..\..\src\FalkForge.Extensions.Firewall\FalkForge.Extensions.Firewall.csproj" />
    <ProjectReference Include="..\..\src\FalkForge.Extensions.Http\FalkForge.Extensions.Http.csproj" />
    <ProjectReference Include="..\..\src\FalkForge.Extensions.Iis\FalkForge.Extensions.Iis.csproj" />
    <ProjectReference Include="..\..\src\FalkForge.Extensions.Sql\FalkForge.Extensions.Sql.csproj" />
    <ProjectReference Include="..\..\src\FalkForge.Extensions.Util\FalkForge.Extensions.Util.csproj" />
    <ProjectReference Include="..\..\src\FalkForge.Localization\FalkForge.Localization.csproj" />
    <ProjectReference Include="..\..\src\FalkForge.Platform.Windows\FalkForge.Platform.Windows.csproj" />
    <ProjectReference Include="..\..\src\FalkForge.Testing\FalkForge.Testing.csproj" />
  </ItemGroup>
</Project>
