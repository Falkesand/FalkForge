<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <NoWarn>$(NoWarn);NU1701</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="xunit.v3" />
    <PackageReference Include="Xunit.StaFact" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\FalkForge.Ui\FalkForge.Ui.csproj" />
    <ProjectReference Include="..\..\src\FalkForge.Testing\FalkForge.Testing.csproj" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="Localization\teststrings.en-US.json" WithCulture="false" LogicalName="FalkForge.Ui.Tests.Localization.teststrings.en-US.json" />
    <EmbeddedResource Include="Localization\teststrings.sv-SE.json" WithCulture="false" LogicalName="FalkForge.Ui.Tests.Localization.teststrings.sv-SE.json" />
  </ItemGroup>
</Project>
