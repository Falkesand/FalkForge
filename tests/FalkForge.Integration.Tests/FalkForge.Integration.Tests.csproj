<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <!-- Deliberate opt-in to the .NET 10 ML-DSA (FIPS 204) API for PQ-hybrid manifest signing —
         see the rationale comment in src/FalkForge.Core/FalkForge.Core.csproj. -->
    <NoWarn>$(NoWarn);SYSLIB5006</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="xunit.v3" />
    <PackageReference Include="Testcontainers" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\FalkForge.Engine\FalkForge.Engine.csproj" />
    <ProjectReference Include="..\..\src\FalkForge.Engine.Elevation\FalkForge.Engine.Elevation.csproj" />
    <ProjectReference Include="..\..\src\FalkForge.Engine.Protocol\FalkForge.Engine.Protocol.csproj" />
    <ProjectReference Include="..\..\src\FalkForge.Compiler.Bundle\FalkForge.Compiler.Bundle.csproj" />
    <ProjectReference Include="..\..\src\FalkForge.Compiler.Msi\FalkForge.Compiler.Msi.csproj" />
    <ProjectReference Include="..\..\src\FalkForge.Extensions.Iis\FalkForge.Extensions.Iis.csproj" />
    <ProjectReference Include="..\..\src\FalkForge.Extensions.Sql\FalkForge.Extensions.Sql.csproj" />
    <ProjectReference Include="..\..\src\FalkForge.Testing\FalkForge.Testing.csproj" />
    <ProjectReference Include="..\..\src\FalkForge.Decompiler\FalkForge.Decompiler.csproj" />
    <ProjectReference Include="..\..\src\FalkForge.Cli\FalkForge.Cli.csproj" />
    <ProjectReference Include="..\..\src\FalkForge.Signing.SignServer\FalkForge.Signing.SignServer.csproj" />
  </ItemGroup>
</Project>
