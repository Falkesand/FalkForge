<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        InstallerTheme.Colors.Light.xaml — Windows 11 Fluent light-mode palette.
        All brush keys consumed by InstallerTheme.xaml structural templates.
        Merged at runtime by App.xaml.cs via ThemeDetector.
    -->

    <!-- Window and surface -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F3F3F3" />
    <SolidColorBrush x:Key="SurfaceBrush"          Color="#FFFFFF" />
    <SolidColorBrush x:Key="BorderBrush"            Color="#E0E0E0" />

    <!-- Text -->
    <SolidColorBrush x:Key="PrimaryTextBrush"  Color="#1A1A1A" />
    <SolidColorBrush x:Key="SubtleTextBrush"   Color="#6E6E6E" />
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#9E9E9E" />

    <!-- Accent (Windows 11 default #0067C0) -->
    <SolidColorBrush x:Key="AccentBrush"                    Color="#0067C0" />
    <SolidColorBrush x:Key="AccentForegroundBrush"          Color="#FFFFFF" />
    <SolidColorBrush x:Key="AccentHoverBrush"               Color="#005FAD" />
    <SolidColorBrush x:Key="AccentPressedBrush"             Color="#00579A" />
    <SolidColorBrush x:Key="AccentDisabledBrush"            Color="#8CB8D8" />
    <SolidColorBrush x:Key="AccentDisabledForegroundBrush"  Color="#FFFFFF" />

    <!-- Secondary button states -->
    <SolidColorBrush x:Key="ButtonHoverBrush"   Color="#F0F0F0" />
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#E8E8E8" />
    <SolidColorBrush x:Key="DisabledBorderBrush" Color="#E0E0E0" />

    <!-- Semantic -->
    <SolidColorBrush x:Key="SuccessTextBrush"  Color="#0F7B0F" />
    <SolidColorBrush x:Key="ErrorTextBrush"    Color="#C42B1C" />
    <SolidColorBrush x:Key="ErrorBorderBrush"  Color="#D04E44" />

    <!-- TextBox states -->
    <SolidColorBrush x:Key="TextBoxReadOnlyBrush"  Color="#F8F8F8" />
    <SolidColorBrush x:Key="TextBoxDisabledBrush"  Color="#F5F5F5" />

    <!-- CheckBox checkmark stroke (white on accent fill) -->
    <SolidColorBrush x:Key="CheckmarkStrokeBrush" Color="#FFFFFF" />

    <!-- Exterior page watermark panel (left 180px) and banner icon -->
    <SolidColorBrush x:Key="WatermarkBrush"   Color="#0067C0" />
    <SolidColorBrush x:Key="BannerIconBrush"  Color="#0067C0" />

</ResourceDictionary>
