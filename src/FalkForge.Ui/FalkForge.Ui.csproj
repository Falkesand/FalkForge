<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <IsPackable>true</IsPackable>
        <OutputType>WinExe</OutputType>
        <TargetFramework>net10.0-windows</TargetFramework>
        <UseWPF>true</UseWPF>
        <RootNamespace>FalkForge.Ui</RootNamespace>
        <Description>WPF installer UI for FalkForge</Description>
        <!-- ReactiveUI.WPF lacks a net10.0 TFM; suppress the transitive NU1701 warning -->
        <NoWarn>NU1701</NoWarn>
    </PropertyGroup>
    <ItemGroup>
        <PackageReference Include="ReactiveUI.WPF" NoWarn="NU1701"/>
        <PackageReference Include="System.Reactive"/>
    </ItemGroup>
    <ItemGroup>
        <InternalsVisibleTo Include="FalkForge.Ui.Tests"/>
    </ItemGroup>
    <ItemGroup>
        <ProjectReference Include="..\FalkForge.Ui.Abstractions\FalkForge.Ui.Abstractions.csproj"/>
        <ProjectReference Include="..\FalkForge.Engine.Protocol\FalkForge.Engine.Protocol.csproj"/>
        <ProjectReference Include="..\FalkForge.Localization\FalkForge.Localization.csproj"/>
    </ItemGroup>
</Project>
