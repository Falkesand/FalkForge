<UserControl x:Class="FalkForge.Ui.Views.WelcomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:FalkForge.Ui.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Wider left panel (180 px) for modern proportions -->
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Dark accent panel — product identity / watermark image -->
        <Grid Grid.Column="0" Background="{DynamicResource WatermarkBrush}">
            <Image Source="{DynamicResource WatermarkImage}" Stretch="Fill" />
        </Grid>

        <!-- Content panel — light Mica-like surface -->
        <StackPanel Grid.Column="1"
                    Margin="24,20,20,20"
                    VerticalAlignment="Center">

            <TextBlock Text="{Binding Title}"
                       Style="{DynamicResource ExteriorTitle}" />
            <TextBlock Text="{Binding Description}"
                       Style="{DynamicResource ExteriorDescription}" />

            <StackPanel Margin="0,16,0,0">
                <Button Content="Install"
                        Style="{DynamicResource WizardButtonPrimary}"
                        Width="110"
                        Margin="0,0,0,8"
                        HorizontalAlignment="Left"
                        Visibility="{Binding CanInstall, Converter={StaticResource BoolToVisibility}}" />
                <Button Content="Uninstall"
                        Style="{DynamicResource WizardButton}"
                        Width="110"
                        Margin="0,0,0,8"
                        HorizontalAlignment="Left"
                        Visibility="{Binding CanUninstall, Converter={StaticResource BoolToVisibility}}" />
                <Button Content="Repair"
                        Style="{DynamicResource WizardButton}"
                        Width="110"
                        HorizontalAlignment="Left"
                        Visibility="{Binding CanRepair, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>

            <!-- Update download progress (shown while checking / downloading) -->
            <StackPanel Orientation="Horizontal"
                        Margin="0,16,0,0"
                        Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BoolToVisibility}}">
                <ProgressBar Width="130"
                             Minimum="0" Maximum="100"
                             Value="{Binding DownloadPercent, Mode=OneWay}" />
                <TextBlock Text="Downloading update..."
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource SubtleTextBrush}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
