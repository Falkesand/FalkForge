<UserControl x:Class="FalkForge.Ui.Views.MaintenancePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <!-- Banner -->
        <Border DockPanel.Dock="Top" Height="59"
                Background="White" BorderThickness="0,0,0,1" BorderBrush="#A0A0A0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}" Style="{StaticResource BannerTitle}" />
                    <TextBlock Text="{Binding Description}" Style="{StaticResource BannerSubtitle}" />
                </StackPanel>
                <Grid Grid.Column="1" Width="49" Height="49" Margin="0,0,8,0">
                    <Rectangle Fill="{DynamicResource BannerIconBrush}" />
                    <Image Source="{DynamicResource BannerIconImage}" Stretch="Fill" />
                </Grid>
            </Grid>
        </Border>

        <!-- Content -->
        <StackPanel Margin="20,16,16,16">
            <StackPanel Margin="0,0,0,10">
                <TextBlock FontSize="10">
                    <Run Text="Product: " FontWeight="SemiBold" />
                    <Run Text="{Binding ProductName, Mode=OneWay}" />
                </TextBlock>
                <TextBlock FontSize="10" Margin="0,4,0,0">
                    <Run Text="Installed version: " FontWeight="SemiBold" />
                    <Run Text="{Binding InstalledVersion, Mode=OneWay}" />
                </TextBlock>
            </StackPanel>

            <StackPanel Margin="0,12,0,0">
                <Button Content="Modify"
                        Width="180" Height="30"
                        Margin="0,0,0,8"
                        HorizontalAlignment="Left"
                        Command="{Binding ModifyCommand}"
                        ToolTip="Change installed features" />
                <Button Content="Repair"
                        Width="180" Height="30"
                        Margin="0,0,0,8"
                        HorizontalAlignment="Left"
                        Command="{Binding RepairCommand}"
                        ToolTip="Repair the installation" />
                <Button Content="Uninstall"
                        Width="180" Height="30"
                        HorizontalAlignment="Left"
                        Command="{Binding UninstallCommand}"
                        ToolTip="Remove the product" />
            </StackPanel>
        </StackPanel>
    </DockPanel>
</UserControl>