<UserControl x:Class="FalkForge.Ui.Views.MaintenancePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:FalkForge.Ui.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>
    <DockPanel>
        <!-- Banner -->
        <Border DockPanel.Dock="Top"
                Height="72"
                Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}"       Style="{DynamicResource BannerTitle}" />
                    <TextBlock Text="{Binding Description}" Style="{DynamicResource BannerSubtitle}" />
                </StackPanel>

                <Border Grid.Column="1"
                        Width="44" Height="44"
                        CornerRadius="6"
                        Margin="0,0,14,0"
                        ClipToBounds="True">
                    <Grid>
                        <Rectangle Fill="{DynamicResource BannerIconBrush}" />
                        <Image Source="{DynamicResource BannerIconImage}" Stretch="Fill" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Content -->
        <StackPanel Margin="24,18,20,18">
            <!-- Installed product info -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock FontFamily="Segoe UI Variable Text, Segoe UI"
                           FontSize="13"
                           Foreground="{DynamicResource PrimaryTextBrush}">
                    <Run Text="Product: " FontWeight="SemiBold" />
                    <Run Text="{Binding ProductName, Mode=OneWay}" />
                </TextBlock>
                <TextBlock FontFamily="Segoe UI Variable Text, Segoe UI"
                           FontSize="13"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Margin="0,6,0,0">
                    <Run Text="Installed version: " FontWeight="SemiBold" />
                    <Run Text="{Binding InstalledVersion, Mode=OneWay}" />
                </TextBlock>
            </StackPanel>

            <!-- Maintenance actions -->
            <StackPanel>
                <Button Content="Modify"
                        Style="{DynamicResource WizardButton}"
                        Width="180"
                        Margin="0,0,0,8"
                        HorizontalAlignment="Left"
                        Command="{Binding ModifyCommand}"
                        ToolTip="Change installed features" />
                <Button Content="Repair"
                        Style="{DynamicResource WizardButton}"
                        Width="180"
                        Margin="0,0,0,8"
                        HorizontalAlignment="Left"
                        Command="{Binding RepairCommand}"
                        ToolTip="Repair the installation" />
                <Button Content="Uninstall"
                        Style="{DynamicResource WizardButtonDestructive}"
                        Width="180"
                        HorizontalAlignment="Left"
                        Command="{Binding UninstallCommand}"
                        ToolTip="Remove the product" />
            </StackPanel>

            <!-- Log path + open buttons -->
            <StackPanel Margin="0,20,0,0"
                        Visibility="{Binding HasLogPath, Converter={StaticResource BoolToVisibility}}">
                <TextBlock FontFamily="Segoe UI Variable Text, Segoe UI"
                           FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           TextWrapping="Wrap"
                           TextTrimming="CharacterEllipsis">
                    <Run Text="Log file: " FontWeight="SemiBold" />
                    <Run Text="{Binding LogPath, Mode=OneWay}" />
                </TextBlock>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="Open log"
                            Style="{DynamicResource WizardButton}"
                            Margin="0,0,8,0"
                            Command="{Binding OpenLogCommand}"
                            ToolTip="Open the installer log in the default text viewer" />
                    <Button Content="Open log folder"
                            Style="{DynamicResource WizardButton}"
                            Command="{Binding OpenLogFolderCommand}"
                            ToolTip="Open the folder containing the installer log" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </DockPanel>
</UserControl>
