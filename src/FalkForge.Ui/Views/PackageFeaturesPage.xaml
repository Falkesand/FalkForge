<UserControl x:Class="FalkForge.Ui.Views.PackageFeaturesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FalkForge.Ui.ViewModels">
    <DockPanel>
        <!-- Banner -->
        <Border DockPanel.Dock="Top"
                Height="72"
                Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}"       Style="{DynamicResource BannerTitle}" />
                    <TextBlock Text="{Binding Description}" Style="{DynamicResource BannerSubtitle}" />
                </StackPanel>

                <Border Grid.Column="1"
                        Width="44" Height="44"
                        CornerRadius="6"
                        Margin="0,0,14,0"
                        ClipToBounds="True">
                    <Grid>
                        <Rectangle Fill="{DynamicResource BannerIconBrush}" />
                        <Image Source="{DynamicResource BannerIconImage}" Stretch="Fill" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Content: one section per package, each a tree of feature checkboxes -->
        <Grid Margin="24,18,20,18">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Sections}"
                              FontFamily="Segoe UI Variable Text, Segoe UI"
                              FontSize="13">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:PackageFeatureSectionViewModel}">
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="{Binding PackageId}"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,6" />
                                <TreeView ItemsSource="{Binding Roots}"
                                          BorderThickness="0"
                                          Background="Transparent">
                                    <TreeView.ItemTemplate>
                                        <HierarchicalDataTemplate DataType="{x:Type vm:PackageFeatureNodeViewModel}"
                                                                  ItemsSource="{Binding Children}">
                                            <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                      Content="{Binding DisplayName}"
                                                      ToolTip="{Binding Description}" />
                                        </HierarchicalDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</UserControl>
