<UserControl x:Class="FalkForge.Ui.Views.UpdateAvailablePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:FalkForge.Ui.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="164" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Watermark panel -->
        <Grid Grid.Column="0" Background="{DynamicResource WatermarkBrush}">
            <Image Source="{DynamicResource WatermarkImage}" Stretch="Fill" />
        </Grid>

        <!-- Content panel -->
        <DockPanel Grid.Column="1" Margin="20,16,16,16">
            <TextBlock DockPanel.Dock="Top"
                       Text="{Binding Title}"
                       Style="{StaticResource ExteriorTitle}" />
            <TextBlock DockPanel.Dock="Top"
                       Text="{Binding Description}"
                       Style="{StaticResource ExteriorDescription}" />

            <!-- Buttons at the bottom -->
            <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                <Button Content="Update Now"
                        Command="{Binding UpdateNowCommand}"
                        Width="100" Height="26"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,6" />
                <Button Content="Later"
                        Command="{Binding LaterCommand}"
                        Width="100" Height="26"
                        HorizontalAlignment="Left" />
            </StackPanel>

            <!-- Release notes -->
            <ScrollViewer Margin="0,12,0,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <TextBlock Text="{Binding ReleaseNotes}"
                           TextWrapping="Wrap"
                           FontSize="12"
                           Foreground="{DynamicResource SubtleTextBrush}" />
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>
