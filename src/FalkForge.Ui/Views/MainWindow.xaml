<Window x:Class="FalkForge.Ui.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FalkForge" Height="420" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}">
    <DockPanel LastChildFill="True">
        <!-- Button bar — white surface, subtle top divider, 52 px tall -->
        <Border DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource BorderBrush}"
                Background="{DynamicResource SurfaceBrush}"
                Padding="0,10,16,10">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="&lt; Back"
                        Style="{DynamicResource WizardButton}"
                        IsEnabled="{Binding CanGoBack}"
                        Click="OnBackClick" />
                <Button Content="Next &gt;"
                        Style="{DynamicResource WizardButtonPrimary}"
                        IsEnabled="{Binding CanGoNext}"
                        Click="OnNextClick" />
                <Button Content="Cancel"
                        Style="{DynamicResource WizardButton}"
                        Margin="12,0,0,0"
                        Click="OnCancelClick" />
            </StackPanel>
        </Border>

        <!-- Page content fills remaining space -->
        <ContentPresenter Content="{Binding CurrentPage}" />
    </DockPanel>
</Window>
