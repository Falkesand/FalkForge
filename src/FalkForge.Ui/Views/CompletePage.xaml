<UserControl x:Class="FalkForge.Ui.Views.CompletePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:FalkForge.Ui.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Dark accent panel -->
        <Grid Grid.Column="0" Background="{DynamicResource WatermarkBrush}">
            <Image Source="{DynamicResource WatermarkImage}" Stretch="Fill" />
        </Grid>

        <!-- Content panel -->
        <DockPanel Grid.Column="1"
                   Margin="24,20,20,20"
                   LastChildFill="False">

            <TextBlock DockPanel.Dock="Top"
                       Text="{Binding Title}"
                       Style="{DynamicResource ExteriorTitle}" />

            <!-- Success / failure status line -->
            <TextBlock DockPanel.Dock="Top"
                       Text="Installation completed successfully."
                       FontFamily="Segoe UI Variable Text, Segoe UI"
                       FontSize="13"
                       Foreground="{DynamicResource SuccessTextBrush}"
                       Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVisibility}}"
                       Margin="0,0,0,8" />
            <TextBlock DockPanel.Dock="Top"
                       Text="Installation failed."
                       FontFamily="Segoe UI Variable Text, Segoe UI"
                       FontSize="13"
                       Foreground="{DynamicResource ErrorTextBrush}"
                       Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"
                       Margin="0,0,0,8" />

            <TextBlock DockPanel.Dock="Top"
                       Text="{Binding Message}"
                       Style="{DynamicResource ExteriorDescription}" />

            <CheckBox DockPanel.Dock="Top"
                      Content="Launch application when closing"
                      IsChecked="{Binding LaunchOnClose}"
                      Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVisibility}}"
                      Margin="0,8,0,0" />

            <Button DockPanel.Dock="Bottom"
                    Content="Close"
                    Style="{DynamicResource WizardButtonPrimary}"
                    HorizontalAlignment="Right"
                    Click="OnCloseClick" />

            <!-- Log path + open buttons -->
            <StackPanel DockPanel.Dock="Bottom"
                        Margin="0,12,0,12"
                        Visibility="{Binding HasLogPath, Converter={StaticResource BoolToVisibility}}">
                <TextBlock FontFamily="Segoe UI Variable Text, Segoe UI"
                           FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           TextWrapping="Wrap"
                           TextTrimming="CharacterEllipsis">
                    <Run Text="Log file: " FontWeight="SemiBold" />
                    <Run Text="{Binding LogPath, Mode=OneWay}" />
                </TextBlock>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="Open log"
                            Style="{DynamicResource WizardButton}"
                            Margin="0,0,8,0"
                            Command="{Binding OpenLogCommand}"
                            ToolTip="Open the installer log in the default text viewer" />
                    <Button Content="Open log folder"
                            Style="{DynamicResource WizardButton}"
                            Command="{Binding OpenLogFolderCommand}"
                            ToolTip="Open the folder containing the installer log" />
                </StackPanel>
            </StackPanel>
        </DockPanel>
    </Grid>
</UserControl>
