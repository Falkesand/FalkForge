<UserControl x:Class="FalkForge.Ui.Views.CompletePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:FalkForge.Ui.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Dark accent panel -->
        <Grid Grid.Column="0" Background="{DynamicResource WatermarkBrush}">
            <Image Source="{DynamicResource WatermarkImage}" Stretch="Fill" />
        </Grid>

        <!-- Content panel -->
        <DockPanel Grid.Column="1"
                   Margin="24,20,20,20"
                   LastChildFill="False">

            <TextBlock DockPanel.Dock="Top"
                       Text="{Binding Title}"
                       Style="{DynamicResource ExteriorTitle}" />

            <!-- Success / failure status line -->
            <TextBlock DockPanel.Dock="Top"
                       Text="Installation completed successfully."
                       FontFamily="Segoe UI Variable Text, Segoe UI"
                       FontSize="13"
                       Foreground="{DynamicResource SuccessTextBrush}"
                       Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVisibility}}"
                       Margin="0,0,0,8" />
            <TextBlock DockPanel.Dock="Top"
                       Text="Installation failed."
                       FontFamily="Segoe UI Variable Text, Segoe UI"
                       FontSize="13"
                       Foreground="{DynamicResource ErrorTextBrush}"
                       Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"
                       Margin="0,0,0,8" />

            <TextBlock DockPanel.Dock="Top"
                       Text="{Binding Message}"
                       Style="{DynamicResource ExteriorDescription}" />

            <CheckBox DockPanel.Dock="Top"
                      Content="Launch application when closing"
                      IsChecked="{Binding LaunchOnClose}"
                      Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVisibility}}"
                      Margin="0,8,0,0" />

            <Button DockPanel.Dock="Bottom"
                    Content="Close"
                    Style="{DynamicResource WizardButtonPrimary}"
                    HorizontalAlignment="Right"
                    Click="OnCloseClick" />
        </DockPanel>
    </Grid>
</UserControl>
