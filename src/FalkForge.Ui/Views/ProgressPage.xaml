<UserControl x:Class="FalkForge.Ui.Views.ProgressPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <!-- Banner -->
        <Border DockPanel.Dock="Top"
                Height="72"
                Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}"       Style="{DynamicResource BannerTitle}" />
                    <TextBlock Text="{Binding Description}" Style="{DynamicResource BannerSubtitle}" />
                </StackPanel>

                <Border Grid.Column="1"
                        Width="44" Height="44"
                        CornerRadius="6"
                        Margin="0,0,14,0"
                        ClipToBounds="True">
                    <Grid>
                        <Rectangle Fill="{DynamicResource BannerIconBrush}" />
                        <Image Source="{DynamicResource BannerIconImage}" Stretch="Fill" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Content -->
        <StackPanel Margin="24,20,20,18">
            <ProgressBar Minimum="0"
                         Maximum="{Binding ProgressTotal}"
                         Value="{Binding ProgressCurrent, Mode=OneWay}"
                         Margin="0,0,0,14" />

            <TextBlock Text="{Binding CurrentPackage}"
                       FontFamily="Segoe UI Variable Text, Segoe UI"
                       FontSize="13"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Margin="0,0,0,6" />
            <TextBlock Text="{Binding StatusText}"
                       FontFamily="Segoe UI Variable Text, Segoe UI"
                       FontSize="12"
                       Foreground="{DynamicResource SubtleTextBrush}" />
        </StackPanel>
    </DockPanel>
</UserControl>
