<UserControl x:Class="FalkForge.Ui.Views.LicensePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <!-- Banner — white surface, 72 px, subtle bottom divider -->
        <Border DockPanel.Dock="Top"
                Height="72"
                Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}"       Style="{DynamicResource BannerTitle}" />
                    <TextBlock Text="{Binding Description}" Style="{DynamicResource BannerSubtitle}" />
                </StackPanel>

                <!-- Icon — rounded accent tile, 44×44 -->
                <Border Grid.Column="1"
                        Width="44" Height="44"
                        CornerRadius="6"
                        Margin="0,0,14,0"
                        ClipToBounds="True">
                    <Grid>
                        <Rectangle Fill="{DynamicResource BannerIconBrush}" />
                        <Image Source="{DynamicResource BannerIconImage}" Stretch="Fill" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Content -->
        <StackPanel Margin="24,18,20,18">
            <TextBox Text="{Binding LicenseText, Mode=OneWay}"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     TextWrapping="Wrap"
                     Height="210"
                     Margin="0,0,0,12" />

            <CheckBox Content="I accept the license agreement"
                      IsChecked="{Binding IsAccepted}" />
        </StackPanel>
    </DockPanel>
</UserControl>
