<UserControl x:Class="FalkForge.Ui.Views.FeaturesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="10">
        <TextBlock Text="{Binding Title}"
                   FontSize="24" FontWeight="Bold"
                   Margin="0,0,0,10" />
        <TextBlock Text="{Binding Description}"
                   FontSize="14"
                   Margin="0,0,0,20" />

        <ListView ItemsSource="{Binding Features}"
                  Height="250"
                  SelectionMode="Single">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Selected" Width="70">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, Mode=OneWay}" IsEnabled="False" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Feature" Width="250"
                                    DisplayMemberBinding="{Binding Title}" />
                    <GridViewColumn Header="Size" Width="100"
                                    DisplayMemberBinding="{Binding DiskSpaceRequired, StringFormat={}{0:N0} bytes}" />
                </GridView>
            </ListView.View>
        </ListView>
    </StackPanel>
</UserControl>
