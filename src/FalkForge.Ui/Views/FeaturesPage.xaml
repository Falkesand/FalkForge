<UserControl x:Class="FalkForge.Ui.Views.FeaturesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <!-- Banner -->
        <Border DockPanel.Dock="Top" Height="59"
                Background="White" BorderThickness="0,0,0,1" BorderBrush="#A0A0A0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}" Style="{StaticResource BannerTitle}"/>
                    <TextBlock Text="{Binding Description}" Style="{StaticResource BannerSubtitle}"/>
                </StackPanel>
                <Grid Grid.Column="1" Width="49" Height="49" Margin="0,0,8,0">
                    <Rectangle Fill="{DynamicResource BannerIconBrush}"/>
                    <Image Source="{DynamicResource BannerIconImage}" Stretch="Fill"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Margin="20,16,16,16">
            <ListView ItemsSource="{Binding Features}"
                      SelectionMode="Single">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Selected" Width="70">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=OneWay}" IsEnabled="False"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Feature" Width="250"
                                        DisplayMemberBinding="{Binding Title}"/>
                        <GridViewColumn Header="Size" Width="100"
                                        DisplayMemberBinding="{Binding DiskSpaceRequired, StringFormat={}{0:N0} bytes}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </DockPanel>
</UserControl>
