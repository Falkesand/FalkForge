<UserControl x:Class="FalkForge.Ui.Views.FeaturesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <!-- Banner -->
        <Border DockPanel.Dock="Top"
                Height="72"
                Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}"       Style="{DynamicResource BannerTitle}" />
                    <TextBlock Text="{Binding Description}" Style="{DynamicResource BannerSubtitle}" />
                </StackPanel>

                <Border Grid.Column="1"
                        Width="44" Height="44"
                        CornerRadius="6"
                        Margin="0,0,14,0"
                        ClipToBounds="True">
                    <Grid>
                        <Rectangle Fill="{DynamicResource BannerIconBrush}" />
                        <Image Source="{DynamicResource BannerIconImage}" Stretch="Fill" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Margin="24,18,20,18">
            <ListView ItemsSource="{Binding Features}"
                      SelectionMode="Single"
                      FontFamily="Segoe UI Variable Text, Segoe UI"
                      FontSize="13">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Selected" Width="70">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=OneWay}"
                                              IsEnabled="False" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Feature" Width="250"
                                        DisplayMemberBinding="{Binding Title}" />
                        <GridViewColumn Header="Size" Width="100"
                                        DisplayMemberBinding="{Binding DiskSpaceRequired, StringFormat={}{0:N0} bytes}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </DockPanel>
</UserControl>
