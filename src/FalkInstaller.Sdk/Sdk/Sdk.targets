<Project>
  <PropertyGroup>
    <!-- The compiled installer project assembly -->
    <_FalkInstallerAssembly>$(TargetPath)</_FalkInstallerAssembly>
  </PropertyGroup>

  <!-- Target that runs after build to generate the installer -->
  <Target Name="FalkGenerateInstaller"
          AfterTargets="Build"
          Condition="'$(FalkOutputType)' != 'None'">

    <Message Importance="high" Text="FalkInstaller: Generating $(FalkOutputType) installer..." />

    <!-- Execute the compiled installer project to generate the MSI/Bundle -->
    <Exec Command="dotnet exec &quot;$(_FalkInstallerAssembly)&quot; --falk-build --output-dir &quot;$(FalkOutputDirectory)&quot; --output-type $(FalkOutputType) --compression $(FalkCompressionLevel) --platform $(FalkPlatform)"
          Condition="'$(FalkOutputType)' == 'Msi' or '$(FalkOutputType)' == 'Bundle'"
          ConsoleToMsBuild="true">
      <Output TaskParameter="ConsoleOutput" PropertyName="_FalkBuildOutput" />
    </Exec>

    <Message Importance="high" Text="FalkInstaller: $(_FalkBuildOutput)" Condition="'$(_FalkBuildOutput)' != ''" />

    <!-- ICE Validation -->
    <Message Importance="high" Text="FalkInstaller: Running ICE validation..."
             Condition="'$(FalkRunIceValidation)' == 'true' and '$(FalkOutputType)' == 'Msi'" />

    <!-- Code signing -->
    <Message Importance="high" Text="FalkInstaller: Signing output..."
             Condition="'$(FalkSignOutput)' == 'true'" />
  </Target>

  <!-- Clean target -->
  <Target Name="FalkClean" AfterTargets="Clean">
    <Message Importance="normal" Text="FalkInstaller: Cleaning generated installers..." />
  </Target>
</Project>
