<UserControl x:Class="FalkInstaller.Ui.Views.CompletePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:FalkInstaller.Ui.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <StackPanel Margin="10">
        <TextBlock Text="{Binding Title}"
                   FontSize="24" FontWeight="Bold"
                   Margin="0,0,0,10" />

        <TextBlock Text="Installation completed successfully."
                   FontSize="14" Foreground="Green"
                   Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVisibility}}"
                   Margin="0,0,0,10" />
        <TextBlock Text="Installation failed."
                   FontSize="14" Foreground="Red"
                   Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"
                   Margin="0,0,0,10" />

        <TextBlock Text="{Binding Message}"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,0,0,20" />

        <CheckBox Content="Launch application when closing"
                  IsChecked="{Binding LaunchOnClose}"
                  Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVisibility}}"
                  Margin="0,0,0,10" />

        <Button Content="Close"
                Width="80" Height="30"
                HorizontalAlignment="Right"
                Click="OnCloseClick" />
    </StackPanel>
</UserControl>
