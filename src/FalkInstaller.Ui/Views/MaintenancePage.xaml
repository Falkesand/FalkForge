<UserControl x:Class="FalkInstaller.Ui.Views.MaintenancePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="10">
        <TextBlock Text="{Binding Title}"
                   FontSize="24" FontWeight="Bold"
                   Margin="0,0,0,10" />
        <TextBlock Text="{Binding Description}"
                   FontSize="14"
                   TextWrapping="Wrap"
                   Margin="0,0,0,20" />

        <StackPanel Margin="0,0,0,10">
            <TextBlock FontSize="13">
                <Run Text="Product: " FontWeight="SemiBold" />
                <Run Text="{Binding ProductName, Mode=OneWay}" />
            </TextBlock>
            <TextBlock FontSize="13" Margin="0,4,0,0">
                <Run Text="Installed version: " FontWeight="SemiBold" />
                <Run Text="{Binding InstalledVersion, Mode=OneWay}" />
            </TextBlock>
        </StackPanel>

        <StackPanel Margin="0,20,0,0">
            <Button Content="Modify"
                    Width="200" Height="35"
                    Margin="0,0,0,10"
                    HorizontalAlignment="Left"
                    Command="{Binding ModifyCommand}"
                    ToolTip="Change installed features" />
            <Button Content="Repair"
                    Width="200" Height="35"
                    Margin="0,0,0,10"
                    HorizontalAlignment="Left"
                    Command="{Binding RepairCommand}"
                    ToolTip="Repair the installation" />
            <Button Content="Uninstall"
                    Width="200" Height="35"
                    HorizontalAlignment="Left"
                    Command="{Binding UninstallCommand}"
                    ToolTip="Remove the product" />
        </StackPanel>
    </StackPanel>
</UserControl>
