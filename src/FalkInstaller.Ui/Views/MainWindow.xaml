<Window x:Class="FalkInstaller.Ui.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FalkInstaller" Height="500" Width="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Page Content -->
        <ContentPresenter Grid.Row="0"
                          Content="{Binding CurrentPage}"
                          Margin="20" />

        <!-- Navigation Buttons -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="20,10">
            <Button Content="Back"
                    Width="80" Height="30"
                    Margin="0,0,10,0"
                    IsEnabled="{Binding CanGoBack}"
                    Click="OnBackClick" />
            <Button Content="Next"
                    Width="80" Height="30"
                    Margin="0,0,10,0"
                    IsEnabled="{Binding CanGoNext}"
                    Click="OnNextClick" />
            <Button Content="Cancel"
                    Width="80" Height="30"
                    Click="OnCancelClick" />
        </StackPanel>
    </Grid>
</Window>
