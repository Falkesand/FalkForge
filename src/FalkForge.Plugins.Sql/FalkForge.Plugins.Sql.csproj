<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
        <RootNamespace>FalkForge.Plugins.Sql</RootNamespace>
        <IsPackable>true</IsPackable>
        <Description>SQL Server discovery, database listing, and connection-testing plugin for FalkForge installer UI</Description>
    </PropertyGroup>
    <ItemGroup>
        <ProjectReference Include="../FalkForge.Core/FalkForge.Core.csproj"/>
        <PackageReference Include="Microsoft.Data.SqlClient"/>
    </ItemGroup>
    <ItemGroup>
        <InternalsVisibleTo Include="FalkForge.Plugins.Sql.Tests"/>
    </ItemGroup>
</Project>
