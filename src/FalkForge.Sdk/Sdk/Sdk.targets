<Project>
  <!-- Second half of the Microsoft.NET.Sdk chain started in Sdk.props: only when this SDK is
       the project's SDK (marker set by Sdk.props). A direct import of this file inside a
       Microsoft.NET.Sdk project (the repo/demo flow) leaves the marker unset and imports
       nothing extra. -->
  <Import Project="Sdk.targets" Sdk="Microsoft.NET.Sdk" Condition="'$(_FalkForgeSdkChainsNetSdk)' == 'true'" />

  <PropertyGroup>
    <!-- The compiled installer project assembly -->
    <_FalkForgeAssembly>$(TargetPath)</_FalkForgeAssembly>
  </PropertyGroup>

  <!-- ============================================================
       Compute the expected artifact path for this project based
       on its FalkOutputType.
       ============================================================ -->
  <Target Name="_ComputeFalkArtifactPath">
    <PropertyGroup>
      <FalkArtifactPath Condition="'$(FalkOutputType)' == 'Msi'">$(TargetDir)$(AssemblyName).msi</FalkArtifactPath>
      <FalkArtifactPath Condition="'$(FalkOutputType)' == 'Bundle'">$(TargetDir)$(AssemblyName).exe</FalkArtifactPath>
      <FalkArtifactPath Condition="'$(FalkOutputType)' == 'Module'">$(TargetDir)$(AssemblyName).msm</FalkArtifactPath>
      <FalkArtifactPath Condition="'$(FalkOutputType)' == 'Patch'">$(TargetDir)$(AssemblyName).msp</FalkArtifactPath>
      <FalkArtifactPath Condition="'$(FalkOutputType)' == 'CustomAction'">$(TargetPath)</FalkArtifactPath>
      <FalkArtifactPath Condition="'$(FalkOutputType)' == 'Msix'">$(TargetDir)$(AssemblyName).msix</FalkArtifactPath>
      <FalkArtifactPath Condition="'$(FalkOutputType)' == 'MsixBundle'">$(TargetDir)$(AssemblyName).msixbundle</FalkArtifactPath>
    </PropertyGroup>
  </Target>

  <!-- ============================================================
       Export this project's FalkForge output metadata so that
       referencing projects can discover artifact paths.
       Returns nothing when FalkOutputType is empty or None.
       ============================================================ -->
  <Target Name="_GetFalkForgeOutput"
          DependsOnTargets="_ComputeFalkArtifactPath"
          Returns="@(_FalkOutput)">
    <ItemGroup Condition="'$(FalkOutputType)' != '' and '$(FalkOutputType)' != 'None'">
      <_FalkOutput Include="$(MSBuildProjectName)">
        <OutputType>$(FalkOutputType)</OutputType>
        <ArtifactPath>$(FalkArtifactPath)</ArtifactPath>
      </_FalkOutput>
    </ItemGroup>
  </Target>

  <!-- ============================================================
       Inline task: writes ProjectOutputs.g.cs from collected
       FalkForge project reference metadata.
       ============================================================ -->
  <UsingTask TaskName="_WriteFalkProjectOutputsSource"
             TaskFactory="RoslynCodeTaskFactory"
             AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <References ParameterType="Microsoft.Build.Framework.ITaskItem[]" Required="true" />
      <OutputFile ParameterType="System.String" Required="true" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System" />
      <Using Namespace="System.IO" />
      <Using Namespace="System.Text" />
      <Code Type="Fragment" Language="cs">
<![CDATA[
var sb = new StringBuilder();
sb.AppendLine("// <auto-generated/>");
sb.AppendLine("// Generated by FalkForge SDK. Do not edit manually.");
sb.AppendLine();
sb.AppendLine("namespace FalkForge;");
sb.AppendLine();
sb.AppendLine("internal static class ProjectOutputs");
sb.AppendLine("{");

foreach (var item in References)
{
    var projectName = item.ItemSpec;
    var outputType = item.GetMetadata("OutputType");
    var artifactPath = item.GetMetadata("ArtifactPath");

    // Sanitize project name to valid C# identifier (allowlist approach)
    var nameSb = new System.Text.StringBuilder();
    foreach (char c in item.ItemSpec)
    {
        if (char.IsLetterOrDigit(c) || c == '_')
            nameSb.Append(c);
        else
            nameSb.Append('_');
    }
    var propertyName = nameSb.ToString();

    // Leading digit needs underscore prefix
    if (propertyName.Length > 0 && char.IsDigit(propertyName[0]))
        propertyName = "_" + propertyName;

    // Empty result fallback
    if (string.IsNullOrWhiteSpace(propertyName))
        propertyName = "_UnnamedProject";

    // XML-escape values for doc comment safety
    var escapedProjectName = System.Security.SecurityElement.Escape(item.ItemSpec);
    var escapedOutputType = System.Security.SecurityElement.Escape(outputType);

    // Escape quotes for verbatim string safety
    var escapedPath = artifactPath.Replace("\"", "\"\"");

    sb.AppendLine(string.Format("    /// <summary>{0} output of {1}</summary>", escapedOutputType, escapedProjectName));
    sb.AppendLine(string.Format("    internal const string {0} = @\"{1}\";", propertyName, escapedPath));
    sb.AppendLine();
}

sb.AppendLine("}");

var dir = System.IO.Path.GetDirectoryName(OutputFile);
if (!string.IsNullOrEmpty(dir) && !System.IO.Directory.Exists(dir))
{
    System.IO.Directory.CreateDirectory(dir);
}

File.WriteAllText(OutputFile, sb.ToString(), new UTF8Encoding(false));
]]>
      </Code>
    </Task>
  </UsingTask>

  <!-- ============================================================
       Query all ProjectReference items for FalkForge output
       metadata and generate ProjectOutputs.g.cs if any are found.
       Runs before CoreCompile so the generated file is included
       in compilation.
       ============================================================ -->
  <Target Name="_GenerateProjectOutputs"
          BeforeTargets="CoreCompile"
          Condition="'@(ProjectReference)' != ''">

    <!-- Query each ProjectReference for its FalkForge output metadata -->
    <MSBuild Projects="@(ProjectReference)"
             Targets="_GetFalkForgeOutput"
             BuildInParallel="true"
             SkipNonexistentTargets="true">
      <Output TaskParameter="TargetOutputs" ItemName="_FalkRefOutput" />
    </MSBuild>

    <!-- Generate source file if any references export FalkForge metadata -->
    <PropertyGroup>
      <_FalkProjectOutputsFile>$(IntermediateOutputPath)ProjectOutputs.g.cs</_FalkProjectOutputsFile>
    </PropertyGroup>

    <_WriteFalkProjectOutputsSource
        References="@(_FalkRefOutput)"
        OutputFile="$(_FalkProjectOutputsFile)"
        Condition="'@(_FalkRefOutput)' != ''" />

    <ItemGroup Condition="'@(_FalkRefOutput)' != ''">
      <Compile Include="$(_FalkProjectOutputsFile)" Condition="!@(Compile->AnyHaveMetadataValue('Identity', '$(_FalkProjectOutputsFile)'))" />
    </ItemGroup>
  </Target>

  <!-- ============================================================
       Target that runs after build to generate the installer
       ============================================================ -->
  <Target Name="FalkGenerateInstaller"
          AfterTargets="Build"
          Condition="'$(FalkOutputType)' != 'None'">

    <Message Importance="high" Text="FalkForge: Generating $(FalkOutputType) installer..." />

    <!-- Belt-and-braces beside the copy-to-output probe: the FalkForge.Engine.Runtime.win-x64
         package sets FalkForgeEngineDir (its props file); surfacing it as FALKFORGE_ENGINE_STUB
         makes the embedded-engine resolution explicit even when the package's copy-to-output
         items are disabled. Empty when the runtime package is not referenced — then the bundle
         compiler's usual resolution order applies unchanged. -->
    <PropertyGroup>
      <_FalkForgeExecEnvironment Condition="'$(FalkForgeEngineDir)' != ''">FALKFORGE_ENGINE_STUB=$(FalkForgeEngineDir)</_FalkForgeExecEnvironment>
    </PropertyGroup>

    <!-- Execute the compiled installer project to generate the MSI/Bundle -->
    <Exec Command="dotnet exec &quot;$(_FalkForgeAssembly)&quot; --forge-build --output-dir &quot;$(FalkOutputDirectory)&quot; --output-type $(FalkOutputType) --compression $(FalkCompressionLevel) --platform $(FalkPlatform)"
          Condition="'$(FalkOutputType)' == 'Msi' or '$(FalkOutputType)' == 'Bundle'"
          EnvironmentVariables="$(_FalkForgeExecEnvironment)"
          ConsoleToMsBuild="true">
      <Output TaskParameter="ConsoleOutput" PropertyName="_FalkBuildOutput" />
    </Exec>

    <Message Importance="high" Text="FalkForge: $(_FalkBuildOutput)" Condition="'$(_FalkBuildOutput)' != ''" />

    <!-- ICE Validation -->
    <Message Importance="high" Text="FalkForge: Running ICE validation..."
             Condition="'$(FalkRunIceValidation)' == 'true' and '$(FalkOutputType)' == 'Msi'" />

    <!-- Code signing -->
    <Message Importance="high" Text="FalkForge: Signing output..."
             Condition="'$(FalkSignOutput)' == 'true'" />
  </Target>

  <!-- Clean target -->
  <Target Name="FalkClean" AfterTargets="Clean">
    <Message Importance="normal" Text="FalkForge: Cleaning generated installers..." />
  </Target>
</Project>
