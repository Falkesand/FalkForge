<Window x:Class="FalkForge.Studio.Export.CiCdExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export CI/CD Pipeline" Height="500" Width="650"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Platform:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox x:Name="PlatformComboBox" Width="200"
                      SelectionChanged="PlatformComboBox_SelectionChanged">
                <ComboBoxItem Content="GitHub Actions" IsSelected="True" />
                <ComboBoxItem Content="Azure DevOps" />
                <ComboBoxItem Content="Jenkins" />
            </ComboBox>
        </StackPanel>

        <TextBox Grid.Row="1" x:Name="PreviewTextBox" IsReadOnly="True"
                 FontFamily="Consolas" FontSize="13"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap" AcceptsReturn="True" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Copy" Width="80" Margin="0,0,8,0" Click="Copy_Click" />
            <Button Content="Save..." Width="80" Margin="0,0,8,0" Click="Save_Click" />
            <Button Content="Cancel" Width="80" IsCancel="True" Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>
