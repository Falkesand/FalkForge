<UserControl x:Class="FalkForge.Studio.Editors.PerfCountersEditor.PerfCountersEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FalkForge.Studio.Editors.PerfCountersEditor">
    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" Text="Performance Counters" FontSize="18" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBlock DockPanel.Dock="Top" Text="Windows Performance Monitor counters registered during installation"
                   FontSize="11" Foreground="Gray" FontStyle="Italic" Margin="0,0,0,8" />
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Add Counter" Click="AddEntry_Click" Padding="8,4" Margin="0,0,8,0" />
            <Button Content="Remove" Click="Remove_Click" Padding="8,4" />
        </StackPanel>
        <DataGrid ItemsSource="{Binding Entries}"
                  SelectedItem="{Binding SelectedEntry}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id"
                                    Binding="{Binding Id, UpdateSourceTrigger=PropertyChanged}"
                                    Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="ToolTip" Value="Unique identifier for this performance counter entry." />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Category Name"
                                    Binding="{Binding CategoryName, UpdateSourceTrigger=PropertyChanged}"
                                    Width="150">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="ToolTip" Value="Performance counter category name as shown in Performance Monitor. Groups related counters." />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Counter Name"
                                    Binding="{Binding CounterName, UpdateSourceTrigger=PropertyChanged}"
                                    Width="150">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="ToolTip" Value="Individual counter name within the category, e.g., 'Requests/sec' or 'Average Response Time'." />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridComboBoxColumn Header="Counter Type"
                                        SelectedItemBinding="{Binding CounterType, UpdateSourceTrigger=PropertyChanged}"
                                        ItemsSource="{x:Static local:PerfCountersEditorViewModel.CounterTypes}"
                                        Width="160">
                    <DataGridComboBoxColumn.ElementStyle>
                        <Style TargetType="ComboBox">
                            <Setter Property="ToolTip" Value="Counter type: NumberOfItems32/64 for raw counts, RateOfCountsPerSecond32/64 for rates, AverageTimer32 for timing." />
                        </Style>
                    </DataGridComboBoxColumn.ElementStyle>
                </DataGridComboBoxColumn>
                <DataGridTextColumn Header="Category Help"
                                    Binding="{Binding CategoryHelp, UpdateSourceTrigger=PropertyChanged}"
                                    Width="150">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="ToolTip" Value="Description shown in Performance Monitor for this counter category." />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Counter Help"
                                    Binding="{Binding CounterHelp, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="ToolTip" Value="Description shown in Performance Monitor for this individual counter." />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
