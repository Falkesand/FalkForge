<UserControl x:Class="FalkForge.Studio.Editors.ShortcutsEditor.ShortcutsEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" Text="Shortcuts" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Add Shortcut" Click="AddEntry_Click" Padding="8,4" Margin="0,0,8,0" />
            <Button Content="Remove" Click="Remove_Click" Padding="8,4" />
        </StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ListBox Grid.Column="0" ItemsSource="{Binding Entries}"
                     SelectedItem="{Binding SelectedEntry}" Margin="0,0,8,0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <StackPanel Grid.Column="1" DataContext="{Binding SelectedEntry}">
                <TextBlock Text="Name" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                <TextBlock Text="Target File" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBox Text="{Binding TargetFile, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                <CheckBox Content="Desktop" IsChecked="{Binding Desktop}" Margin="0,0,0,8" />
                <CheckBox Content="Start Menu" IsChecked="{Binding StartMenu}" Margin="0,0,0,8" />
                <CheckBox Content="Startup" IsChecked="{Binding Startup}" Margin="0,0,0,8" />
                <TextBlock Text="Arguments" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBox Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                <TextBlock Text="Description" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                <TextBlock Text="Icon File" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBox Text="{Binding IconFile, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                <TextBlock Text="Working Directory" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBox Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                <TextBlock Text="Start Menu Subfolder" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBox Text="{Binding StartMenuSubfolder, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
            </StackPanel>
        </Grid>
    </DockPanel>
</UserControl>
