<UserControl x:Class="FalkForge.Studio.Editors.SqlEditor.SqlEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" Text="SQL Databases" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!-- Database list -->
            <DockPanel Grid.Column="0">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                    <Button Content="Add DB" Click="AddDatabase_Click" Padding="8,4" Margin="0,0,4,0" />
                    <Button Content="Remove" Click="RemoveDatabase_Click" Padding="8,4" />
                </StackPanel>
                <ListBox ItemsSource="{Binding Databases}"
                         SelectedItem="{Binding SelectedDatabase}"
                         DisplayMemberPath="Id" />
            </DockPanel>
            <!-- Detail panel -->
            <DockPanel Grid.Column="2" DataContext="{Binding SelectedDatabase}">
                <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Id:" Margin="0,0,8,4" VerticalAlignment="Center" />
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"
                             ToolTip="Unique identifier for this database configuration." />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Server:" Margin="0,0,8,4" VerticalAlignment="Center" />
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Server, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"
                             ToolTip="SQL Server instance name, e.g., localhost, .\SQLEXPRESS, or server\instance" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Database:" Margin="0,0,8,4" VerticalAlignment="Center" />
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"
                             ToolTip="Name of the database to create or target." />
                    <CheckBox Grid.Row="3" Grid.ColumnSpan="2" Content="Create on Install" IsChecked="{Binding CreateOnInstall}" Margin="0,0,0,4"
                              ToolTip="Automatically create the database during installation if it does not exist." />
                    <CheckBox Grid.Row="4" Grid.ColumnSpan="2" Content="Drop on Uninstall" IsChecked="{Binding DropOnUninstall}" Margin="0,0,0,4"
                              ToolTip="Drop the database when the product is uninstalled. Warning: all data will be lost." />
                    <TextBlock Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                               Text="Specify the SQL Server instance and database name for script execution"
                               FontSize="11" Foreground="Gray" FontStyle="Italic" Margin="0,4,0,0" />
                </Grid>
                <TextBlock DockPanel.Dock="Top" Text="Scripts" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4" />
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                    <Button Content="Add Script" Click="AddScript_Click" Padding="8,4" Margin="0,0,4,0" />
                    <Button Content="Remove Script" Click="RemoveScript_Click" Padding="8,4" />
                </StackPanel>
                <DataGrid ItemsSource="{Binding Scripts}"
                          SelectedItem="{Binding SelectedScript}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Id" Binding="{Binding Id, UpdateSourceTrigger=PropertyChanged}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="ToolTip" Value="Unique identifier for this SQL script entry." />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Source File" Binding="{Binding SourceFile, UpdateSourceTrigger=PropertyChanged}" Width="200">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="ToolTip" Value="Path to a .sql script file to execute during installation, relative to project." />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridCheckBoxColumn Header="On Install" Binding="{Binding ExecuteOnInstall}" Width="80">
                            <DataGridCheckBoxColumn.ElementStyle>
                                <Style TargetType="CheckBox">
                                    <Setter Property="ToolTip" Value="Execute this script during product installation." />
                                </Style>
                            </DataGridCheckBoxColumn.ElementStyle>
                        </DataGridCheckBoxColumn>
                        <DataGridCheckBoxColumn Header="On Uninstall" Binding="{Binding ExecuteOnUninstall}" Width="80">
                            <DataGridCheckBoxColumn.ElementStyle>
                                <Style TargetType="CheckBox">
                                    <Setter Property="ToolTip" Value="Execute this script during product uninstallation." />
                                </Style>
                            </DataGridCheckBoxColumn.ElementStyle>
                        </DataGridCheckBoxColumn>
                        <DataGridTextColumn Header="Sequence" Binding="{Binding Sequence, UpdateSourceTrigger=PropertyChanged}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="ToolTip" Value="Execution order when multiple scripts target the same database." />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
