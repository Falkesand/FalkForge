<UserControl x:Class="FalkForge.Studio.Editors.BundleChain.BundleChainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FalkForge.Studio.Editors.BundleChain">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" Text="Bundle Chain" FontSize="18" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBlock DockPanel.Dock="Top" Text="Packages execute top-to-bottom. Rollback boundaries define rollback groups."
                   FontSize="11" Foreground="Gray" FontStyle="Italic" Margin="0,0,0,8" />

        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Move Up" Command="{Binding MoveUpCommand}" Padding="8,4" Margin="0,0,4,0"
                    ToolTip="Move selected item earlier in the chain." />
            <Button Content="Move Down" Command="{Binding MoveDownCommand}" Padding="8,4" Margin="0,0,4,0"
                    ToolTip="Move selected item later in the chain." />
            <Button Content="Add Rollback Boundary" Click="AddRollbackBoundary_Click" Padding="8,4" Margin="0,0,4,0"
                    ToolTip="Insert a rollback boundary after the selected item." />
            <Button Content="Remove" Click="RemoveItem_Click" Padding="8,4"
                    ToolTip="Remove the selected item from the chain." />
        </StackPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Chain list -->
            <ListBox Grid.Column="0" ItemsSource="{Binding ChainItems}"
                     SelectedItem="{Binding SelectedItem}" Margin="0,0,8,0">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:ChainItemViewModel}">
                        <Border Padding="8,6" Margin="2" CornerRadius="3">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#F0F4F8" />
                                    <Setter Property="BorderBrush" Value="#D0D5DD" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRollbackBoundary}" Value="True">
                                            <Setter Property="Background" Value="#FFF3F0" />
                                            <Setter Property="BorderBrush" Value="#E74C3C" />
                                            <Setter Property="BorderThickness" Value="1,2" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <!-- Order number -->
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"
                                           FontSize="11" Foreground="#888">
                                    <TextBlock.Text>
                                        <Binding Path="DisplayOrder" StringFormat="#{0}" />
                                    </TextBlock.Text>
                                </TextBlock>
                                <!-- Name and type -->
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding PackageType}" FontSize="11" Foreground="Gray">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRollbackBoundary}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <!-- Flow arrow -->
                                <TextBlock Grid.Column="2" Text="&#x2193;" FontSize="14" Foreground="#AAA"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Property editor for selected item -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel DataContext="{Binding SelectedItem}">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="Properties" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />

                    <!-- Rollback boundary notice -->
                    <Border Background="#FFF3F0" BorderBrush="#E74C3C" BorderThickness="1" Padding="8" Margin="0,0,0,12"
                            CornerRadius="3"
                            Visibility="{Binding IsRollbackBoundary, Converter={StaticResource BoolToVis}}">
                        <TextBlock TextWrapping="Wrap" Text="Rollback Boundary: If a package after this boundary fails, only packages within this boundary group are rolled back." />
                    </Border>

                    <!-- Name -->
                    <TextBlock Text="Name" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"
                             ToolTip="Display name for this chain item." />

                    <!-- Package-only properties -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRollbackBoundary}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Text="Package Type" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBlock Text="Type of installer package in the chain."
                                   FontSize="11" Foreground="Gray" FontStyle="Italic" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{x:Static local:BundleChainViewModel.PackageTypes}"
                                  SelectedItem="{Binding PackageType, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,0,0,12"
                                  ToolTip="Package type (MsiPackage, ExePackage, etc.)." />

                        <TextBlock Text="Install Condition" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBlock Text="Leave empty to always install. Use MSI condition syntax."
                                   FontSize="11" Foreground="Gray" FontStyle="Italic" Margin="0,0,0,4" />
                        <TextBox Text="{Binding InstallCondition, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"
                                 ToolTip="MSI condition determining whether this package installs." />

                        <CheckBox Content="Vital" IsChecked="{Binding Vital}" Margin="0,0,0,4"
                                  ToolTip="If checked, the entire bundle fails when this package fails." />
                        <TextBlock Text="A vital package failure stops the entire bundle installation."
                                   FontSize="11" Foreground="Gray" FontStyle="Italic" Margin="0,0,0,12" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</UserControl>
