<UserControl x:Class="FalkForge.Studio.Editors.DialogEditor.DialogEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FalkForge.Studio.Editors.DialogEditor">
    <DockPanel>
        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Template:" VerticalAlignment="Center" Margin="0,0,4,0" />
            <ComboBox ItemsSource="{Binding TemplateNames}" SelectedItem="{Binding SelectedTemplateName}"
                      Width="120" Margin="0,0,8,0" />
            <Button Content="Load Template" Command="{Binding LoadTemplateCommand}" Padding="8,4"
                    ToolTip="Replace all dialogs with the selected template's predefined set." />
        </StackPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="200" />
            </Grid.ColumnDefinitions>

            <!-- Left panel: Dialog list -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="Dialogs" FontWeight="Bold" Margin="0,0,0,4" />
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,4,0,0">
                    <Button Content="Add" Command="{Binding AddDialogCommand}" Padding="8,2" Margin="0,0,4,0" />
                    <Button Content="Remove" Command="{Binding RemoveDialogCommand}" Padding="8,2" />
                </StackPanel>
                <ListBox ItemsSource="{Binding Dialogs}" SelectedItem="{Binding SelectedDialog}"
                         DisplayMemberPath="Name" />
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" />

            <!-- Center panel: Visual preview -->
            <DockPanel Grid.Column="2" Margin="4,0">
                <TextBlock DockPanel.Dock="Top" FontWeight="Bold" Margin="0,0,0,4">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="Preview: {0} ({1} x {2})">
                            <Binding Path="SelectedDialogName" FallbackValue="(none)" />
                            <Binding Path="SelectedDialogWidth" />
                            <Binding Path="SelectedDialogHeight" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,4,0,0">
                    <Button Content="Add Control" Command="{Binding AddControlCommand}" Padding="8,2" Margin="0,0,4,0" />
                    <Button Content="Remove Control" Command="{Binding RemoveControlCommand}" Padding="8,2" />
                </StackPanel>
                <Border BorderBrush="Gray" BorderThickness="1" Background="#F0F0F0">
                    <ItemsControl x:Name="DialogCanvas" ItemsSource="{Binding Controls}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas x:Name="PreviewCanvas" Background="White" ClipToBounds="True" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <local:DialogControlPresenter Control="{Binding}"
                                    Width="{Binding Width}" Height="{Binding Height}"
                                    MouseLeftButtonDown="Control_MouseLeftButtonDown" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </DockPanel>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" />

            <!-- Right panel: Property grid -->
            <ScrollViewer Grid.Column="4" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="4,0,0,0">
                    <TextBlock Text="Dialog Properties" FontWeight="Bold" Margin="0,0,0,8" />

                    <TextBlock Text="Name" Margin="0,0,0,2" />
                    <TextBox Text="{Binding SelectedDialogName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                    <TextBlock Text="Title" Margin="0,0,0,2" />
                    <TextBox Text="{Binding SelectedDialogTitle, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                    <TextBlock Text="Width" Margin="0,0,0,2" />
                    <TextBox Text="{Binding SelectedDialogWidth, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                    <TextBlock Text="Height" Margin="0,0,0,2" />
                    <TextBox Text="{Binding SelectedDialogHeight, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                    <Separator Margin="0,4,0,8" />
                    <TextBlock Text="Control Properties" FontWeight="Bold" Margin="0,0,0,8" />

                    <TextBlock Text="Type" Margin="0,0,0,2" />
                    <ComboBox ItemsSource="{Binding ControlTypes}" SelectedItem="{Binding SelectedControlType}" Margin="0,0,0,8" />

                    <TextBlock Text="X" Margin="0,0,0,2" />
                    <TextBox Text="{Binding SelectedControlX, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                    <TextBlock Text="Y" Margin="0,0,0,2" />
                    <TextBox Text="{Binding SelectedControlY, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                    <TextBlock Text="Width" Margin="0,0,0,2" />
                    <TextBox Text="{Binding SelectedControlWidth, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                    <TextBlock Text="Height" Margin="0,0,0,2" />
                    <TextBox Text="{Binding SelectedControlHeight, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                    <TextBlock Text="Text" Margin="0,0,0,2" />
                    <TextBox Text="{Binding SelectedControlText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                    <TextBlock Text="Property" Margin="0,0,0,2" />
                    <TextBox Text="{Binding SelectedControlProperty, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                    <TextBlock Text="Condition" Margin="0,0,0,2" />
                    <TextBox Text="{Binding SelectedControlCondition, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</UserControl>
