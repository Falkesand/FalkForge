<UserControl x:Class="FalkForge.Studio.Editors.DiffViewer.DiffViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:diff="clr-namespace:FalkForge.Studio.Diff">
    <DockPanel Margin="8">
        <TextBlock Text="Project Comparison" FontSize="18" FontWeight="Bold" DockPanel.Dock="Top" Margin="0,0,0,8" />

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Compare With..." Command="{Binding CompareWithCommand}" Padding="12,4" />
            <TextBlock Text="{Binding ComparisonFilePath, TargetNullValue='(none)'}"
                       VerticalAlignment="Center" Margin="12,0,0,0" Foreground="Gray" />
        </StackPanel>

        <TextBlock Text="{Binding StatusText}" DockPanel.Dock="Top" Margin="0,0,0,8"
                   FontStyle="Italic" Foreground="Gray" />

        <DataGrid ItemsSource="{Binding DiffEntries}" AutoGenerateColumns="False"
                  CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single"
                  BorderThickness="1" BorderBrush="Gray"
                  GridLinesVisibility="Horizontal" AlternatingRowBackground="#F8F8F8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Property Path" Binding="{Binding Path}" Width="2*" />
                <DataGridTextColumn Header="Current Value" Binding="{Binding LeftValue}" Width="*" />
                <DataGridTextColumn Header="Comparison Value" Binding="{Binding RightValue}" Width="*" />
                <DataGridTextColumn Header="Status" Binding="{Binding Kind}" Width="90" />
            </DataGrid.Columns>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static diff:DiffKind.Added}">
                            <Setter Property="Background" Value="#DDFFDD" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static diff:DiffKind.Removed}">
                            <Setter Property="Background" Value="#FFDDDD" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static diff:DiffKind.Modified}">
                            <Setter Property="Background" Value="#FFFFCC" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>
    </DockPanel>
</UserControl>
