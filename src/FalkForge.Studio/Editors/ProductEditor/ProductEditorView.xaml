<UserControl x:Class="FalkForge.Studio.Editors.ProductEditor.ProductEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8" MaxWidth="500">
            <TextBlock Text="Product Information" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" />

            <TextBlock Text="Output Format" FontWeight="SemiBold" Margin="0,0,0,4" />
            <ComboBox ItemsSource="{Binding ProjectTypes}" SelectedItem="{Binding SelectedProjectType}"
                      ToolTip="Choose the installer package format. MSI for traditional Windows Installer, Bundle for multi-package EXE, MSIX for modern Windows apps."
                      Margin="0,0,0,12" />

            <TextBlock Text="Product Name *" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="The display name shown in Add/Remove Programs and installer dialogs."
                     Margin="0,0,0,12" />

            <TextBlock Text="Manufacturer *" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBox Text="{Binding Manufacturer, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Company or author name. Used in the default install path (Program Files\Manufacturer\Product)."
                     Margin="0,0,0,12" />

            <TextBlock Text="Version *" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Text="Used for upgrade detection and displayed in Add/Remove Programs."
                       Foreground="Gray" FontSize="11" FontStyle="Italic" Margin="0,0,0,4" />
            <TextBox Text="{Binding Version, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Product version in Major.Minor.Build format (e.g., 1.2.3). MSI supports up to 255.255.65535."
                     Margin="0,0,0,12" />

            <TextBlock Text="Upgrade Code" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Text="Generate once and never change. Format: {xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx}"
                       Foreground="Gray" FontSize="11" FontStyle="Italic" Margin="0,0,0,4" />
            <TextBox Text="{Binding UpgradeCode, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="A fixed GUID identifying this product line. Must remain the same across all versions to enable upgrades."
                     Margin="0,0,0,12" FontFamily="Consolas" />

            <TextBlock Text="Architecture" FontWeight="SemiBold" Margin="0,0,0,4" />
            <ComboBox ItemsSource="{Binding Architectures}" SelectedItem="{Binding Architecture}"
                      ToolTip="Target processor architecture. x64 for 64-bit, x86 for 32-bit, arm64 for ARM devices."
                      Margin="0,0,0,12" />

            <TextBlock Text="Install Scope" FontWeight="SemiBold" Margin="0,0,0,4" />
            <ComboBox ItemsSource="{Binding Scopes}" SelectedItem="{Binding Scope}"
                      ToolTip="Per-machine installs for all users (requires elevation). Per-user installs for the current user only."
                      Margin="0,0,0,12" />

            <TextBlock Text="Description" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Optional description shown in Add/Remove Programs."
                     AcceptsReturn="True" Height="60" TextWrapping="Wrap" Margin="0,0,0,12" />

            <TextBlock Text="{Binding ValidationError}" Foreground="Red" FontStyle="Italic" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
