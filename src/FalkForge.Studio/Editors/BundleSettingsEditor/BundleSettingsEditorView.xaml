<UserControl x:Class="FalkForge.Studio.Editors.BundleSettingsEditor.BundleSettingsEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FalkForge.Studio.Editors.BundleSettingsEditor">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8" MaxWidth="500">
            <TextBlock Text="Bundle Settings" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" />

            <TextBlock Text="Name *" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"
                     ToolTip="Bundle product name shown in Add/Remove Programs." />

            <TextBlock Text="Manufacturer *" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBox Text="{Binding Manufacturer, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"
                     ToolTip="Company name for the bundle installer." />

            <TextBlock Text="Version" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBox Text="{Binding Version, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"
                     ToolTip="Bundle version in Major.Minor.Build format." />

            <TextBlock Text="Upgrade Code" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Text="Generate once and never change. Enables upgrade detection."
                       FontSize="11" Foreground="Gray" FontStyle="Italic" Margin="0,0,0,4" />
            <TextBox Text="{Binding UpgradeCode, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"
                     FontFamily="Consolas"
                     ToolTip="Fixed GUID for this bundle product line. Must stay the same across versions." />

            <TextBlock Text="Scope" FontWeight="SemiBold" Margin="0,0,0,4" />
            <ComboBox ItemsSource="{x:Static local:BundleSettingsEditorViewModel.Scopes}"
                      SelectedItem="{Binding Scope}" Margin="0,0,0,12"
                      ToolTip="Per-machine installs for all users (requires elevation). Per-user for current user only." />

            <TextBlock Text="UI Type" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Text="Silent is useful for enterprise deployment via SCCM/Intune."
                       FontSize="11" Foreground="Gray" FontStyle="Italic" Margin="0,0,0,4" />
            <ComboBox ItemsSource="{x:Static local:BundleSettingsEditorViewModel.UiTypes}"
                      SelectedItem="{Binding UiType}" Margin="0,0,0,12"
                      ToolTip="BuiltIn shows the standard installer UI with progress. Silent runs with no user interface." />

            <TextBlock Text="License File" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBox Text="{Binding LicenseFile, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"
                     ToolTip="Path to an RTF or TXT license file displayed during installation." />

            <TextBlock Text="Download Throttle (bytes/sec)" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Text="Useful to prevent saturating network bandwidth during deployment."
                       FontSize="11" Foreground="Gray" FontStyle="Italic" Margin="0,0,0,4" />
            <TextBox Text="{Binding DownloadThrottle, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"
                     ToolTip="Maximum download speed in bytes per second for remote payloads. 0 for unlimited." />
        </StackPanel>
    </ScrollViewer>
</UserControl>
