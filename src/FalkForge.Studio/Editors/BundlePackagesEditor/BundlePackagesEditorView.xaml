<UserControl x:Class="FalkForge.Studio.Editors.BundlePackagesEditor.BundlePackagesEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FalkForge.Studio.Editors.BundlePackagesEditor">
    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" Text="Bundle Packages" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Add Package" Click="AddEntry_Click" Padding="8,4" Margin="0,0,8,0" />
            <Button Content="Remove" Click="Remove_Click" Padding="8,4" />
        </StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ListBox Grid.Column="0" ItemsSource="{Binding Entries}"
                     SelectedItem="{Binding SelectedEntry}" Margin="0,0,8,0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Type}" FontSize="11" Foreground="Gray" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel DataContext="{Binding SelectedEntry}">
                    <TextBlock Text="Id" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBox Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                    <TextBlock Text="Type" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{x:Static local:BundlePackagesEditorViewModel.PackageTypes}"
                              SelectedItem="{Binding Type, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                    <TextBlock Text="Source Path" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBox Text="{Binding SourcePath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                    <TextBlock Text="Display Name" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                    <CheckBox Content="Vital" IsChecked="{Binding Vital}" Margin="0,0,0,8" />
                    <CheckBox Content="Is Prerequisite" IsChecked="{Binding IsPrerequisite}" Margin="0,0,0,12" />
                    <TextBlock Text="Install Condition" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBox Text="{Binding InstallCondition, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                    <TextBlock Text="Detection Mode" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{x:Static local:BundlePackagesEditorViewModel.DetectionModes}"
                              SelectedItem="{Binding DetectionMode, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                    <TextBlock Text="Authenticode Thumbprint" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBox Text="{Binding AuthenticodeThumbprint, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"
                             FontFamily="Consolas" />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</UserControl>
