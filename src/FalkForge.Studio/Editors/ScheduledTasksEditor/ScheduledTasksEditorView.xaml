<UserControl x:Class="FalkForge.Studio.Editors.ScheduledTasksEditor.ScheduledTasksEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FalkForge.Studio.Editors.ScheduledTasksEditor">
    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" Text="Scheduled Tasks" FontSize="18" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBlock DockPanel.Dock="Top" Text="Windows Task Scheduler entries created during installation"
                   FontSize="11" Foreground="Gray" FontStyle="Italic" Margin="0,0,0,8" />
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Add Task" Click="AddEntry_Click" Padding="8,4" Margin="0,0,8,0" />
            <Button Content="Remove" Click="Remove_Click" Padding="8,4" />
        </StackPanel>
        <DataGrid ItemsSource="{Binding Entries}"
                  SelectedItem="{Binding SelectedEntry}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id"
                                    Binding="{Binding Id, UpdateSourceTrigger=PropertyChanged}"
                                    Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="ToolTip" Value="Unique identifier for this scheduled task entry." />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Name"
                                    Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                    Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="ToolTip" Value="Display name of the scheduled task as shown in Task Scheduler." />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Command"
                                    Binding="{Binding Command, UpdateSourceTrigger=PropertyChanged}"
                                    Width="150">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="ToolTip" Value="Path to the executable to run, relative to the install directory." />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Arguments"
                                    Binding="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}"
                                    Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="ToolTip" Value="Command-line arguments passed to the executable." />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Working Dir"
                                    Binding="{Binding WorkingDir, UpdateSourceTrigger=PropertyChanged}"
                                    Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="ToolTip" Value="Working directory for the task. Defaults to the install directory if empty." />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridComboBoxColumn Header="Trigger Type"
                                        SelectedItemBinding="{Binding TriggerType, UpdateSourceTrigger=PropertyChanged}"
                                        ItemsSource="{x:Static local:ScheduledTasksEditorViewModel.TriggerTypes}"
                                        Width="100">
                    <DataGridComboBoxColumn.ElementStyle>
                        <Style TargetType="ComboBox">
                            <Setter Property="ToolTip" Value="When the task runs: Daily, Weekly, AtLogon, AtStartup, or OnIdle." />
                        </Style>
                    </DataGridComboBoxColumn.ElementStyle>
                </DataGridComboBoxColumn>
                <DataGridTextColumn Header="Schedule"
                                    Binding="{Binding Schedule, UpdateSourceTrigger=PropertyChanged}"
                                    Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="ToolTip" Value="Schedule details for time-based triggers, e.g., '08:00' for daily or 'Mon,Wed,Fri' for weekly." />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Run As User"
                                    Binding="{Binding RunAsUser, UpdateSourceTrigger=PropertyChanged}"
                                    Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="ToolTip" Value="User account under which the task runs, e.g., SYSTEM, LocalService, or a domain account." />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridCheckBoxColumn Header="Elevated"
                                        Binding="{Binding RunElevated, UpdateSourceTrigger=PropertyChanged}"
                                        Width="70">
                    <DataGridCheckBoxColumn.ElementStyle>
                        <Style TargetType="CheckBox">
                            <Setter Property="ToolTip" Value="Run the task with highest privileges (administrator)." />
                        </Style>
                    </DataGridCheckBoxColumn.ElementStyle>
                </DataGridCheckBoxColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
